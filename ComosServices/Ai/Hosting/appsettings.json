{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },

    "Serilog": {
        "Using": [
            "Serilog.Enrichers.Environment",
            "Serilog.Enrichers.Process",
            "Serilog.Enrichers.Thread",
            "Serilog.Sinks.Trace"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.AspNetCore": "Information",
                "Comos.Services.Ai": "Information"
            }
        },
        "Enrich": [
            "WithThreadId",
            "WithMachineName",
            "WithProcessId"
        ],

        "Properties": {
            "ServiceName": "COMOS AI services",
            "ServiceVersion": "1.0.0"
        },
        "WriteTo": [
            {
                "Name": "Trace",
                "Args": {
                    "outputTemplate": "[COMOS {Timestamp:o} {Level:u3} {ProcessId:D6} {ThreadId:D6} {MachineName} {ServiceName} {ServiceVersion}] {Message:lj} || {Properties} {NewLine}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "C:\\Users\\z004uz0p\\AppData\\Local\\Temp\\comos_ai_api-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7,
                    "shared": true,
                    "outputTemplate": "[COMOS {Timestamp:o} {Level:u3} {ProcessId:D6} {ThreadId:D6} {MachineName} {ServiceName} {ServiceVersion}] {Message:lj} || {Properties} {NewLine}{Exception}"
                }
            }


        ]
    }

}
