<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- 
           Der private probing path auf interop ist nicht mehr notwendig
           <probing privatePath="Interop"/>
      -->
      <!-- Hier liegen 3rdParty Assemblies, die von unseren eigenen Komponenten benötigt werden -->
      <probing privatePath="NET_Runtime" />
    </assemblyBinding>
  </runtime>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>