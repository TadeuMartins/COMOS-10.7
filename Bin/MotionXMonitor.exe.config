<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!--
					 Der private probing path auf interop ist nicht mehr notwendig
					 <probing privatePath="Interop"/>
			-->
      <!-- Hier liegen 3rdParty Assemblies, die von unseren eigenen Komponenten benötigt werden -->
      <probing privatePath="NET_Runtime"/>
    </assemblyBinding>
  </runtime>

  <!--Trace settings START-->

  <appSettings>
    <!--Deletes all .log files in the 'Listeners' directory.-->
    <!--Moves all. log files in the 'Listeners' directory to the specified directory.-->
    <!--<add key="MoveTraceLogsTo" value="Backup" />-->
  </appSettings>

  <system.diagnostics>
    <switches>
      <!-- Query, XMLConnector, XMLAdapter(SAP) -->
      <add name="QueryX" value="Debug" />
    </switches>
    <sources>
      <source name="QueryX" switchName="QueryX" switchType="System.Diagnostics.SourceSwitch"/>
    </sources>
    <trace autoflush="true" indentsize="2" />
  </system.diagnostics>

  <!--Trace settings END-->

</configuration>