<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    
  <startup useLegacyV2RuntimeActivationPolicy="true">
	<supportedRuntime version="v4.0"/>
  </startup>
	
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- 
           Der private probing path auf interop ist nicht mehr notwendig
           <probing privatePath="Interop"/>
      -->
	  <!-- Hier liegen 3rdParty Assemblies, die von unseren eigenen Komponenten benötigt werden -->
      <probing privatePath="NET_Runtime;NET_Runtime\Teamcenter\SOA;Custom;ThirdParty\DlhSoft;ThirdParty\MPXJ_NET;ThirdParty\IModelSDK\bin;ThirdParty\IModelSDK_2_0\bin\ICS;Custom\Extensions\Kernel;Custom\Extensions\Kernel\Managed;Internal\Extensions\Kernel;Internal\Extensions\Kernel\Managed;ThirdParty\SQLite\1.0.107.0;ThirdParty\Microsoft;ThirdParty\OdaTeigha;ThirdParty\qrcode;ThirdParty\CefSharp\x86;NET_Runtime\PDFNet\x86;ThirdParty\Serilog;ThirdParty\Owin;ThirdParty\Autofac"/>
    </assemblyBinding>
  </runtime>
</configuration>
