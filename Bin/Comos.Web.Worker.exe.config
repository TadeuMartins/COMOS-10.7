<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--set useLegacyV2RuntimeActivationPolicy=true if old custom dlls needed-->
  <!--<startup useLegacyV2RuntimeActivationPolicy="true"><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/></startup>-->
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
    <!--<appSettings>
    <add key="serilog:minimum-level" value="Verbose" />
    <add key="serilog:using:Seq" value="Serilog.Sinks.Seq" />
    <add key="serilog:write-to:Seq.serverUrl" value="http://localhost:5341" />
    <add key="serilog:write-to:Seq.apiKey" value="" />
    <add key="serilog:using:Thread" value="Serilog.Enrichers.Thread" />
    <add key="serilog:enrich:WithThreadId" />

    <add key="serilog:using:Process" value="Serilog.Enrichers.Process" />
    <add key="serilog:enrich:WithProcessId" />

    <add key="serilog:using:Environment" value="Serilog.Enrichers.Environment" />
    <add key="serilog:enrich:WithMachineName" />
    <add key="serilog:enrich:WithEnvironmentUserName" />
    <add key="serilog:enrich:WithCorrelationId"/>
  </appSettings>-->
  <runtime>
    <AppContextSwitchOverrides value="Switch.System.Net.DontEnableSystemDefaultTlsVersions=false"/>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- Location of 3rdParty Assemblies, which are used by COMOS -->
      <probing privatePath="NET_Runtime;NET_Runtime\Teamcenter\SOA;Custom;ThirdParty\DlhSoft;Custom\Extensions\Kernel;Custom\Extensions\Kernel\Managed;Internal\Extensions\Kernel;Internal\Extensions\Kernel\Managed;ThirdParty\Microsoft;ThirdParty\OdaTeigha;NET_Runtime\PDFNet\x86;ThirdParty\Serilog;ThirdParty\Owin"/>

        <dependentAssembly>
        <assemblyIdentity name="Comos.Printer.IPrinter" culture="neutral" publicKeyToken="91e2475731c73cff"/>
        <codeBase version="1.0.0.0" href="FILE://C:/Program Files (x86)/Common Files/Siemens/COMOS Revision Printer/Version 1/Comos.Printer.IPrinter.dll"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Comos.Printer.Exceptions" culture="neutral" publicKeyToken="91e2475731c73cff"/>
        <codeBase version="1.0.0.0" href="FILE://C:/Program Files (x86)/Common Files/Siemens/COMOS Revision Printer/Version 1/Comos.Printer.Exceptions.dll"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Comos.Printer.PrintDocument" culture="neutral" publicKeyToken="91e2475731c73cff"/>
        <codeBase version="1.0.0.0" href="FILE://C:/Program Files (x86)/Common Files/Siemens/COMOS Revision Printer/Version 1/Comos.Printer.PrintDocument.dll"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Comos.Printer.JobSettings" culture="neutral" publicKeyToken="91e2475731c73cff"/>
        <codeBase version="1.0.0.0" href="FILE://C:/Program Files (x86)/Common Files/Siemens/COMOS Revision Printer/Version 1/Comos.Printer.JobSettings.dll"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Comos.Printer.Environment" culture="neutral" publicKeyToken="91e2475731c73cff"/>
        <codeBase version="1.0.0.0" href="FILE://C:/Program Files (x86)/Common Files/Siemens/COMOS Revision Printer/Version 1/Comos.Printer.Environment.dll"/>
      </dependentAssembly>


      <!-- This entry is necessary for snapshots -->
      <dependentAssembly>
          <assemblyIdentity name="Microsoft.Identity.Client" publicKeyToken="0a613f4dd989e8ae" culture="neutral"/>
          <bindingRedirect oldVersion="0.0.0.0-4.34.0.0" newVersion="4.35.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Owin" publicKeyToken="31bf3856ad364e35" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-4.2.2.0" newVersion="4.2.2.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.IdentityModel.Logging" publicKeyToken="31bf3856ad364e35" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-1.1.5.0" newVersion="1.1.5.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.Logging" publicKeyToken="adb9793829ddae60" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.Logging.Abstractions" publicKeyToken="adb9793829ddae60" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.DependencyInjection.Abstractions" publicKeyToken="adb9793829ddae60" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.Primitives" publicKeyToken="adb9793829ddae60" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Owin.FileSystems" publicKeyToken="31bf3856ad364e35" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-4.2.2.0" newVersion="4.2.2.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Owin.StaticFiles" publicKeyToken="31bf3856ad364e35" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-4.2.2.0" newVersion="4.2.2.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.IdentityModel.Tokens.Jwt" publicKeyToken="31bf3856ad364e35" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.21.0.0" newVersion="6.21.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Buffers" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-4.0.3.0" newVersion="4.0.3.0"/>
      </dependentAssembly>
    </assemblyBinding>
    <!-- Uncomment the following option, if loading assemblies from remote sources (such as network drives) is necessary.
          The value for XmlAttribute 'enabled' can be set to 'true' or 'false'. For further information please visit the MSDN websites. -->
    <!-- <loadFromRemoteSources enabled="true"/> -->
  </runtime>
  <system.diagnostics>
    <switches>
      <add name="AppGlobal" value="Warning"/>
      <add name="ComAppGlobal" value="Warning"/>
      <add name="Kernel" value="Warning"/>
      <add name="Workflow" value="Warning"/>
      <add name="QueryX" value="Warning"/>
      <add name="ComosIModelSynchronizer" value="All"/>
    </switches>
    <sources>
      <source name="AppGlobal" switchName="AppGlobal" switchType="System.Diagnostics.SourceSwitch"/>
      <!--<source name="AppGlobal" switchName="AppGlobal" switchType="System.Diagnostics.SourceSwitch">
        <listeners>
          <add name="DefaultListener" />
           -->
      <!--Uncomment the following line if the trace should be written to the shared Serilog.-->
      <!--
          <add name="Serilog" />
          -->
      <!--Comment out the following line if the trace should be written to the default trace.-->
      <!--
          <remove name="Default" />
        </listeners>
      </source>-->
        <source name="ComAppGlobal" switchName="ComAppGlobal" switchType="System.Diagnostics.SourceSwitch"/>
      <source name="Kernel" switchName="Kernel" switchType="System.Diagnostics.SourceSwitch"/>
      <source name="Workflow" switchName="Workflow" switchType="System.Diagnostics.SourceSwitch"/>
      <source name="QueryX" switchName="QueryX" switchType="System.Diagnostics.SourceSwitch"/>
      <source name="ComosIModelSynchronizer" switchName="ComosIModelSynchronizer" switchType="System.Diagnostics.SourceSwitch">
        <listeners>
          <add name="DefaultListener"/>
          <!-- Uncomment the following line if the trace should be written to the shared Serilog.-->
          <!--<add name="Serilog" />-->
          <!--Comment out the following line if the trace should be written to the default trace.-->
          <!--remove name="Default"/>-->
        </listeners>
      </source>
    </sources>
    <sharedListeners>
      <add name="DefaultListener" type="Comos.Global.Diagnostics.CDefaultTraceListener, Comos.Global" traceOutputOptions="ThreadId"/>

      <!-- Uncomment the following line if you want to use File-Logging with the shared ComosTextWriterTraceListener.-->
      <add name="ComosTextWriterTraceListener" type="Comos.Global.Diagnostics.ComosTextWriterTraceListener, Comos.Global"
        initializeData="FileDirectory=d:\temp, MaxFileLength=104857600, MaxFileCount=1, Mode=WrapAround" traceOutputOptions="DateTime, ProcessId, ThreadId"/>
      <!--<add name="Serilog" type="SerilogTraceListener.SerilogTraceListener, SerilogTraceListener" initializeData="Comos.WebWorker" />-->

      <!--
                        You can use the ComosTextWriterTraceListener to enable logging into a file.
                        Use the initializeData Attribute to set the parameter values you want.
                        If you don't set a value for a Parameter, the default value will be used.
                        e.g.: initializeData="FileDirectory=, MaxFileLength=104857600, MaxFileCount=5, Mode=CutOff",
                        will log to C:\Documents and Settings\<user>\Local Settings\Application Data\Comos_Industry_Solutions\Listeners
                        If you want enable logging into a File but you don't want to change the default values,
                        you can leave the initializeData empty or rather remove it.

                        Parameter:              Remark                              Default Value:
                        ___________________________________________________________________________________
                        FileDirectory           Environment Variables supported     <LocalAppData>\Comos_Industry_Solutions\Listeners
                                                                        e.g. %USERPROFILE% or %TEMP%                         (typically: C:\Documents and Settings\<user>\Local Settings\Application Data\Comos_Industry_Solutions\Listeners)
                        MaxFileLength           in bytes                            104857600 -> 100MB
                        MaxFileCount                                                5
                        Mode                                                        CutOff

                        Possible values for Mode:
                        Value:                  Description:
                        ___________________________________________________________________________________
                        CutOff                  If the maximum file length is reached, writing to the file will be turned off.
                        CreateNew               If the maximum file length is reached, a new file will be created. If more than
                                                                        the maximum file count files are created the oldest file will be deleted.
                        Truncate                If the maximum file length is reached, the current file will be cleared and
                                                                        rewritten from the beginning.
                        WrapAround              If the maximum file length is reached, the oldest entries in the file will be
                                                                        deleted and new entries are written to the end of the file.

                 -->

    </sharedListeners>

    <trace autoflush="true" indentsize="2"/>
  </system.diagnostics>
</configuration>
