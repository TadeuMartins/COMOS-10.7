<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
   The .NET 2.0 build of nunit-agent only
   runs under .NET 2.0 or higher. The setting
   useLegacyV2RuntimeActivationPolicy only applies
   under .NET 4.0 and permits use of mixed mode
   assemblies, which would otherwise not load
   correctly.
  -->
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <!--
     Nunit-agent is normally run by the console or gui
     runners and not independently. In normal usage,
     the runner specifies which runtime should be used.

     Do NOT add any supportedRuntime elements here,
     since they may prevent the runner from controlling
     the runtime that is used!
    -->
    <requiredRuntime version="v4.0" />
    <supportedRuntime version="v4.0"/>
  </startup>

  <!-- Set the level for tracing NUnit itself -->
  <!-- 0=Off 1=Error 2=Warning 3=Info 4=Debug -->
  <system.diagnostics>
    <switches>
      <add name="NTrace" value="0" />
        <add name="AppGlobal" value="All" />
        <add name="ComAppGlobal" value="All"/>
        <add name="Kernel" value="Warning"/>
        <add name="Workflow" value="Warning"/>
        <add name="QueryX" value="Warning" />
    </switches>

    <sources>
      <source name="AppGlobal" switchName="AppGlobal" switchType="System.Diagnostics.SourceSwitch">
      </source>
      <source name="ComAppGlobal" switchName="ComAppGlobal" switchType="System.Diagnostics.SourceSwitch">
      </source>
      <source name="Kernel" switchName="Kernel" switchType="System.Diagnostics.SourceSwitch">
      </source>
      <source name="Workflow" switchName="Workflow" switchType="System.Diagnostics.SourceSwitch">
      </source>
      <source name="QueryX" switchName="QueryX" switchType="System.Diagnostics.SourceSwitch">
      </source>
    </sources>

    <trace autoflush="true" indentsize="2" />

  </system.diagnostics>

  <runtime>
    <!-- Ensure that test exceptions don't crash NUnit -->
    <legacyUnhandledExceptionPolicy enabled="1" />

    <!-- Run partial trust V2 assemblies in full trust under .NET 4.0 -->
    <loadFromRemoteSources enabled="true" />

    <!-- Look for addins in the addins directory for now -->
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
	  <probing privatePath="lib;addins;NET_Runtime;NET_Runtime\Teamcenter\SOA;Custom;ThirdParty\DlhSoft;ThirdParty\MPXJ;ThirdParty\IModelSDK\bin;Custom\Extensions\Kernel;Custom\Extensions\Kernel\Managed;Internal\Extensions\Kernel;Internal\Extensions\Kernel\Managed;ThirdParty\SQLite\1.0.107.0;ThirdParty\Microsoft;ThirdParty\ODA\Teigha_19.12;ThirdParty\Castle;ThirdParty\EasyHook;ThirdParty\Autofac" />
   </assemblyBinding>

  </runtime>

</configuration>