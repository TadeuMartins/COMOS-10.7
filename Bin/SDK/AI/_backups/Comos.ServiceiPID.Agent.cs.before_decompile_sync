using System;
using System.Collections.Generic;
using System.ComponentModel.Composition;
using System.Globalization;
using System.IO;
using System.IO.Compression;
using System.Reflection;
using System.Runtime.InteropServices;
using System.Text;
using System.Xml;
using Comos.Ai.Functions;
using Plt;
using ComosQSGlobalObj;
using ComosVBInterface;

namespace Comos.ServiceiPID.Agent
{
    /// <summary>
    /// Tool que importa equipamentos de um Excel (gerado pelo ServiceiPID)
    /// para dentro de um diagrama COMOS, criando objetos, posiciona-os nas
    /// coordenadas X/Y do diagrama, e cria conexões (From/To).
    ///
    /// Uses native XLSX parsing (ZIP + XML) instead of Excel COM to avoid
    /// the 30-second per-iteration timeout in COMOS AI Client.
    ///
    /// [Export] + AIComosTool = MEF auto-discovery by COMOS ChatControl.
    /// </summary>
    [Export(typeof(AIComosTool))]
    public class ImportAgent : AIComosTool
    {
        // Required by AIComosTool interface — scope for tool discovery
        public string ToolScope { get { return "ServiceiPID"; } }

        // Workset must be STATIC with PRIVATE getter — COMOS sets it via
        // reflection InvokeMember (same pattern as ReportAgent in SDK\AI)
        private static IComosDWorkset _workset;
        public static IComosDWorkset Workset { private get { return _workset; } set { _workset = value; } }

        // ── Colunas do Excel (zero-based index) ──
        // Layout gerado pelo gateway /comos/export-excel:
        //   A=Tag(0), B=Description(1), C=Type(2), D=X_mm(3), E=Y_mm(4), F=Page(5),
        //   G=From(6), H=To(7), I=SystemFullName(8), J=Confidence(9)
        private const int COL_TAG       = 0;
        private const int COL_DESC      = 1;
        // COL_TYPE = 2 (não usado na importação)
        private const int COL_X         = 3;
        private const int COL_Y         = 4;
        // COL_PAGE = 5 (não usado)
        private const int COL_CONN_DE   = 6;
        private const int COL_CONN_PARA = 7;
        private const int COL_SYSFN     = 8;
        // COL_CONF = 9 (não usado)

        // Conectores padrão (igual ao script VBS)
        private const string PIN_IN  = "EB01";   // Entrada
        private const string PIN_OUT = "EB02";   // Saída

        // SFN especial para aterramento
        private const string GROUND_SFN = "@30|M41|A50|A10|A20|A20|A20|A10";

        // ── Contator (bobina) / Contato (child) ──
        private const string CONTATOR_SFN = "@30|M41|A50|A30|A20|A15|A10|A10|A50|A20|A10|A10";
        private const string CONTATO_SFN  = "@10|A50|A20|A60|A05";
        private const string CONTATO_CHILD_NAME_SUFFIX = "_CT";

        // ── TOOL 1: Importar por caminho de arquivo ────────────────────────

        [AiFunction(
            "import_equipment_from_excel",
            "Imports equipment from a ServiceiPID analysis Excel file into " +
            "the current COMOS electrical diagram. Creates objects, draws " +
            "them on the document, and establishes connections (From/To). " +
            "The Excel file must have been generated by the ServiceiPID " +
            "analysis export.")]
        public object ImportEquipmentFromExcel(
            [DescribeParameter(
                "Full path to the Excel file (.xlsx) generated by ServiceiPID analysis export",
                ExampleValue = @"C:\temp\analysis_result.xlsx")]
            string excelFilePath,

            [DescribeParameter(
                "SystemUID of the target COMOS document (diagram) to draw equipment on",
                ExampleValue = "A5B4Z726ZU")]
            string documentUID,

            [DescribeParameter(
                "Document type number in COMOS (usually 29 for electrical and P&ID diagrams)",
                ExampleValue = "29")]
            int documentType)
        {
            if (Workset == null)
                return new { success = false, error = "Workset not available. COMOS must be running with an open project." };

            if (string.IsNullOrWhiteSpace(excelFilePath))
                return new { success = false, error = "excelFilePath is required." };

            string normalizedExcelFilePath = (excelFilePath ?? "").Trim();

            // ── INLINE SINGLE-OBJECT DRAW (routed from shim) ──
            // Accept tolerant prefixes: __INLINE__: / INLINE: / _INLINE_:
            string inlinePayload;
            string inlineB64;
            if (TryExtractPayload(normalizedExcelFilePath, new[] { "INLINE_B64:", "__INLINE_B64__:", "INLINE64:" }, out inlineB64))
            {
                string decoded = TryDecodeBase64(inlineB64);
                if (!string.IsNullOrWhiteSpace(decoded))
                    return DrawSingleObject(documentUID, documentType, decoded);
            }
            if (TryExtractPayload(normalizedExcelFilePath, new[] { "__INLINE__:", "INLINE:", "_INLINE_:", "__INLINE:" }, out inlinePayload) ||
                TryExtractInlineJson(normalizedExcelFilePath, out inlinePayload))
            {
                return DrawSingleObject(documentUID, documentType, inlinePayload);
            }

            // ── INLINE CONNECTION (routed from shim) ──
            // Accept tolerant prefixes: __CONNECT__: / CONNECT: / _CONNECT_:
            string connectPayload;
            string connectB64;
            if (TryExtractPayload(normalizedExcelFilePath, new[] { "CONNECT_B64:", "__CONNECT_B64__:", "CONNECT64:" }, out connectB64))
            {
                string decoded = TryDecodeBase64(connectB64);
                if (!string.IsNullOrWhiteSpace(decoded))
                    return ConnectObjects(documentUID, documentType, decoded);
            }
            if (TryExtractPayload(normalizedExcelFilePath, new[] { "__CONNECT__:", "CONNECT:", "_CONNECT_:", "__CONNECT:" }, out connectPayload) ||
                TryExtractConnectJson(normalizedExcelFilePath, out connectPayload))
            {
                return ConnectObjects(documentUID, documentType, connectPayload);
            }

            // If documentUID is empty or "ACTIVE", use the currently opened document
            string resolvedDocUID = (documentUID ?? "").Trim();
            bool isActiveMode = string.IsNullOrWhiteSpace(resolvedDocUID) || resolvedDocUID.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase);

            if (isActiveMode)
            {
                // Try to get the active document directly — returns null if none is open
                string activeError;
                object activeDoc = GetActiveDocument(out activeError);
                if (activeDoc != null)
                {
                    try { resolvedDocUID = ((dynamic)activeDoc).SystemUID; } catch { }
                }
                if (string.IsNullOrWhiteSpace(resolvedDocUID))
                    return new { success = false, error = activeError ?? "No document is currently open in COMOS. Please open the target drawing (P&ID or Diagram) before using interactive mode." };
            }

            try
            {
                return DoImport(normalizedExcelFilePath, resolvedDocUID, documentType, "Sheet1");
            }
            catch (Exception ex)
            {
                return new { success = false, error = ex.Message, stackTrace = ex.StackTrace };
            }
        }

        // ── Core import logic ──────────────────────────────────────────────

        private object DoImport(string excelFilePath, string documentUID, int documentType, string sheetName)
        {
            string normalizedPath = (excelFilePath ?? "").Trim();

            // Defensive: handle inline/connect payloads here as well
            // (in case caller path bypasses ImportEquipmentFromExcel pre-checks)
            string inlinePayload;
            string inlineB64;
            if (TryExtractPayload(normalizedPath, new[] { "INLINE_B64:", "__INLINE_B64__:", "INLINE64:" }, out inlineB64))
            {
                string decoded = TryDecodeBase64(inlineB64);
                if (!string.IsNullOrWhiteSpace(decoded))
                    return DrawSingleObject(documentUID, documentType, decoded);
            }
            if (TryExtractPayload(normalizedPath, new[] { "__INLINE__:", "INLINE:", "_INLINE_:", "__INLINE:" }, out inlinePayload) ||
                TryExtractInlineJson(normalizedPath, out inlinePayload))
                return DrawSingleObject(documentUID, documentType, inlinePayload);

            string connectPayload;
            string connectB64;
            if (TryExtractPayload(normalizedPath, new[] { "CONNECT_B64:", "__CONNECT_B64__:", "CONNECT64:" }, out connectB64))
            {
                string decoded = TryDecodeBase64(connectB64);
                if (!string.IsNullOrWhiteSpace(decoded))
                    return ConnectObjects(documentUID, documentType, decoded);
            }
            if (TryExtractPayload(normalizedPath, new[] { "__CONNECT__:", "CONNECT:", "_CONNECT_:", "__CONNECT:" }, out connectPayload) ||
                TryExtractConnectJson(normalizedPath, out connectPayload))
                return ConnectObjects(documentUID, documentType, connectPayload);

            string cachePayload;
            bool isCachePayload = TryExtractPayload(normalizedPath, new[] { "__CACHE_TSV_B64__:", "CACHE_TSV_B64:", "CACHE:" }, out cachePayload);

            // ── Validar arquivo (somente quando não for payload em cache) ──
            if (!isCachePayload && !File.Exists(normalizedPath))
                return new { success = false, error = "File not found: " + normalizedPath };

            List<string[]> rows;
            try
            {
                if (isCachePayload)
                {
                    rows = ReadRowsFromCachedPayload(cachePayload);
                }
                else
                {
                    // ── Ler XLSX nativamente (ZIP + XML, sem Excel COM!) ──
                    rows = ReadXlsx(normalizedPath, sheetName);
                }
            }
            catch (Exception ex)
            {
                return new { success = false, error = "Failed to read import data: " + ex.Message };
            }

            if (rows.Count < 2)
                return new { success = false, error = "Excel file has no data rows (only header or empty)." };

            // ── Carregar documento COMOS ──
            var project = Workset.GetCurrentProject();
            if (project == null)
                return new { success = false, error = "No project is currently open in COMOS." };

            object docObj = ResolveDocument(documentType, documentUID);
            if (docObj == null)
                return new { success = false, error = string.Format("Document not found (Type={0}, UID/Name={1}). Check the document UID or name.", documentType, documentUID) };

            // Verify the resolved object is actually a document.
            // ResolveDocument may return a unit or other non-document object if
            // all typed resolvers fail and the path-based fallback matches a unit.
            if (!(docObj is IComosDDocument))
            {
                // Fallback: try the currently active (open) document in COMOS
                string activeError;
                object activeDoc = GetActiveDocument(out activeError);
                if (activeDoc != null && activeDoc is IComosDDocument)
                {
                    docObj = activeDoc;
                }
                else
                {
                    return new { success = false, error = string.Format(
                        "Resolved object for '{0}' is not a COMOS document (got {1}). " +
                        "Please open the target drawing in COMOS and try again, or use the document SystemUID.",
                        documentUID, docObj.GetType().Name) };
                }
            }

            // ── QSGlobalObj para GetOrCreateObject ──
            _QsGlobalObj qsGlobal;
            try
            {
                qsGlobal = (_QsGlobalObj)(new QsGlobalObjClass());
            }
            catch (Exception ex)
            {
                return new { success = false, error = "Failed to instantiate QsGlobalObj: " + ex.Message };
            }

            // ── GlobalCastings (criado UMA VEZ para todo o import) ──
            // Use direct .NET interop (same as draw_single_object) — NOT
            // Activator.CreateInstance with COM ProgID, which may produce
            // a different RCW and cause typed IRoDevice calls to fail.
            Comos.WSP.RoUtilities.GlobalCastings globalCastings = null;
            try { globalCastings = new Comos.WSP.RoUtilities.GlobalCastings(); }
            catch { /* will skip drawing if GlobalCastings not available */ }

            // ── GlobalUtilities — for GU_GetLikeConnector (create parallel connectors) ──
            dynamic globalUtilities = null;
            Type guType = Type.GetTypeFromProgID("ComosROUtilities.GlobalUtilities");
            if (guType != null)
            {
                try { globalUtilities = Activator.CreateInstance(guType); }
                catch { /* connections still work, but can't create "like" connectors */ }
            }

            try
            {
                // ── Caches ──
                var baseBySFN = new Dictionary<string, IComosDCDevice>();
                var objByTag  = new Dictionary<string, object>();
                var toDraw    = new List<DrawInfo>();

                // ── Contator/Contato caches ──
                var coilObjByTag    = new Dictionary<string, IComosDDevice>();   // contator (bobina)
                var contactObjByTag = new Dictionary<string, IComosDDevice>();   // contato (child)
                var connTargetByTag = new Dictionary<string, IComosDDevice>();   // alvo de conexão (bobina ou contato)
                var coilDrawnTags   = new HashSet<string>();                     // bobinas já desenhadas

                int createdCount = 0;
                int drawnCount   = 0;
                int connCount    = 0;
                int skipCount    = 0;
                var errors       = new List<string>();

                // ═══════════════════════════════════════════════════════
                // PASSO 1 — Criar objetos (lógico, sem desenhar ainda)
                // ═══════════════════════════════════════════════════════
                for (int i = 1; i < rows.Count; i++) // skip header row [0]
                {
                    var cells = rows[i];
                    int rowNum = i + 1; // 1-based row number for error msgs
                    try
                    {
                        string tag = CellStr(cells, COL_TAG);
                        if (string.IsNullOrWhiteSpace(tag)) { skipCount++; continue; }

                        string sfn = CellStr(cells, COL_SYSFN);
                        if (string.IsNullOrWhiteSpace(sfn)) { skipCount++; continue; }

                        // Obter base (CDevice) pelo SystemFullName
                        IComosDCDevice baseObj;
                        if (!baseBySFN.TryGetValue(sfn, out baseObj))
                        {
                            baseObj = project.GetCDeviceBySystemFullname(sfn, 3);
                            if (baseObj != null)
                                baseBySFN[sfn] = baseObj;
                        }

                        if (baseObj == null)
                        {
                            errors.Add(string.Format("Row {0}: CDevice not found for SFN '{1}'", rowNum, sfn));
                            continue;
                        }

                        // GetOrCreate
                        object deviceObj;
                        if (!objByTag.TryGetValue(tag, out deviceObj))
                        {
                            deviceObj = qsGlobal.GetOrCreateObject(docObj, tag, baseObj, null);
                            if (deviceObj != null)
                            {
                                objByTag[tag] = deviceObj;
                            }
                        }

                        if (deviceObj == null)
                        {
                            errors.Add(string.Format("Row {0}: Failed to create object '{1}'", rowNum, tag));
                            continue;
                        }

                        createdCount++;

                        // ── Force CDevice to the intended base object ──
                        // (same fix as draw_single_object — GetOrCreateObject may
                        //  return an existing object with a different CDevice,
                        //  causing the wrong symbol to be drawn)
                        var dev = deviceObj as IComosDDevice;
                        if (dev != null)
                        {
                            try { qsGlobal.CDeviceChange(dev, baseObj); }
                            catch { /* fallback below */ }

                            try { dev.CDevice = baseObj; }
                            catch { /* best effort */ }
                        }

                        // Setar descrição
                        if (dev != null)
                        {
                            string desc = CellStr(cells, COL_DESC);
                            if (!string.IsNullOrEmpty(desc))
                                dev.Description = desc;

                            double x = CellDbl(cells, COL_X, 100.0);
                            double y = CellDbl(cells, COL_Y, 100.0);

                            // ── Lógica especial para Contator ──
                            if (sfn == CONTATOR_SFN)
                            {
                                if (IsCoilDescription(desc))
                                {
                                    // Bobina: manter CDevice de contator, desenhar bobina
                                    coilObjByTag[tag] = dev;
                                    connTargetByTag[tag] = dev;
                                    try
                                    {
                                        var bpDocs = dev.BackPointerDocObjs();
                                        if (bpDocs == null || bpDocs.Count() == 0)
                                        {
                                            toDraw.Add(new DrawInfo { Tag = tag, DeviceObj = deviceObj, Device = dev, BaseObj = baseObj, X = x, Y = y });
                                            coilDrawnTags.Add(tag);
                                        }
                                    }
                                    catch
                                    {
                                        toDraw.Add(new DrawInfo { Tag = tag, DeviceObj = deviceObj, Device = dev, BaseObj = baseObj, X = x, Y = y });
                                        coilDrawnTags.Add(tag);
                                    }
                                }
                                else
                                {
                                    // Contato: reutilizar o MESMO objeto, apenas
                                    // trocar o CDevice de Contator → Contato.
                                    // Assim o contato tem seus próprios EB01/EB02,
                                    // sem criar objeto extra nem sufixo _CT.
                                    IComosDCDevice contactBase;
                                    if (!baseBySFN.TryGetValue(CONTATO_SFN, out contactBase))
                                    {
                                        contactBase = project.GetCDeviceBySystemFullname(CONTATO_SFN, 3);
                                        if (contactBase != null) baseBySFN[CONTATO_SFN] = contactBase;
                                    }

                                    if (contactBase != null)
                                    {
                                        // Trocar CDevice para Contato no próprio objeto
                                        try { qsGlobal.CDeviceChange(dev, contactBase); } catch { }
                                        try { dev.CDevice = contactBase; } catch { }

                                        connTargetByTag[tag] = dev;

                                        try
                                        {
                                            var bpDocs = dev.BackPointerDocObjs();
                                            if (bpDocs == null || bpDocs.Count() == 0)
                                                toDraw.Add(new DrawInfo { Tag = tag, DeviceObj = deviceObj, Device = dev, BaseObj = contactBase, X = x, Y = y });
                                        }
                                        catch
                                        {
                                            toDraw.Add(new DrawInfo { Tag = tag, DeviceObj = deviceObj, Device = dev, BaseObj = contactBase, X = x, Y = y });
                                        }
                                    }
                                    else
                                    {
                                        // Fallback: CDevice do contato não encontrado
                                        connTargetByTag[tag] = dev;
                                        errors.Add(string.Format("Row {0}: Contact CDevice not found (SFN '{1}')", rowNum, CONTATO_SFN));
                                    }
                                }
                            }
                            else
                            {
                                // Objeto normal: desenhar e conectar diretamente
                                connTargetByTag[tag] = dev;
                                try
                                {
                                    var bpDocs = dev.BackPointerDocObjs();
                                    if (bpDocs == null || bpDocs.Count() == 0)
                                        toDraw.Add(new DrawInfo { Tag = tag, DeviceObj = deviceObj, Device = dev, BaseObj = baseObj, X = x, Y = y });
                                }
                                catch
                                {
                                    toDraw.Add(new DrawInfo { Tag = tag, DeviceObj = deviceObj, Device = dev, BaseObj = baseObj, X = x, Y = y });
                                }
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        errors.Add(string.Format("Row {0} create error: {1}", rowNum, ex.Message));
                    }
                }

                // ═══════════════════════════════════════════════════════
                // PASSO 2 — Posicionar objetos no diagrama (BATCH)
                //   Abre o Report UMA VEZ, desenha todos, salva UMA VEZ
                // ═══════════════════════════════════════════════════════
                if (toDraw.Count > 0)
                {
                    dynamic report = null;
                    try
                    {
                        var doc = docObj as IComosDDocument;
                        if (doc == null)
                        {
                            errors.Add(string.Format("PASSO 2 SKIP: docObj is not IComosDDocument (type={0}, uid={1}, clr={2}). No objects will be drawn.",
                                documentType, documentUID, docObj != null ? docObj.GetType().Name : "null"));
                        }
                        else
                        {
                            report = doc.Report();
                            if (report != null)
                            {
                                report.Open();
                                dynamic repDoc = report.ReportDocument;

                                foreach (var item in toDraw)
                                {
                                    try
                                    {
                                        // Re-fetch latest device object right before drawing
                                        // to avoid stale RCW / wrong bound symbol in batch mode.
                                        IComosDDevice devToDraw = item.Device;
                                        if (item.BaseObj != null)
                                        {
                                            try
                                            {
                                                object latestObj = qsGlobal.GetOrCreateObject(docObj, item.Tag, item.BaseObj, null);
                                                var latestDev = latestObj as IComosDDevice;
                                                if (latestDev != null)
                                                    devToDraw = latestDev;
                                            }
                                            catch { }
                                        }

                                        // Re-force CDevice RIGHT BEFORE drawing
                                        // (identical to draw_single_object sequence)
                                        if (devToDraw != null && item.BaseObj != null)
                                        {
                                            try { qsGlobal.CDeviceChange(devToDraw, item.BaseObj); } catch { }
                                            try { devToDraw.CDevice = item.BaseObj; } catch { }
                                        }

                                        dynamic ro = repDoc.CreateReportObject(item.X, item.Y, item.X, item.Y);
                                        ro.CreateXObj("ComosWspRoDevice.WspRoDevice");

                                        // Create GlobalCastings per object (same behavior as single draw)
                                        // to avoid stale COM binding across batch iterations.
                                        var gcObj = new Comos.WSP.RoUtilities.GlobalCastings();
                                        IRoDevice iroDev = gcObj.GC_GetIRODevice((object)ro);
                                        iroDev.Determination = DeterminationLevel.C_DL_Fix;
                                        iroDev.Device = devToDraw;  // typed IComosDDevice

                                        // Do NOT save per-object — batch save once after loop
                                        drawnCount++;
                                    }
                                    catch (Exception ex)
                                    {
                                        errors.Add(string.Format("Draw '{0}' at ({1},{2}): {3}", item.Tag, item.X, item.Y, ex.Message));
                                    }
                                }

                                // Save ONCE after all objects have been drawn (batch optimisation)
                                if (drawnCount > 0)
                                    report.Save();
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        errors.Add("Report batch draw error: " + ex.Message);
                    }
                    finally
                    {
                        // Keep report/diagram open after PDF import so the user can
                        // immediately review created objects and connections.
                        // try { if (report != null) report.Close(); } catch { }
                    }
                }

                // ═══════════════════════════════════════════════════════
                // PASSO 3 — Conexões (com lógica de contator/contato)
                // ═══════════════════════════════════════════════════════
                // Rastrear pares já conectados para evitar duplicatas
                // (cada conexão A↔B aparece nas duas linhas do Excel)
                var connectedPairs = new HashSet<string>();
                for (int i = 1; i < rows.Count; i++)
                {
                    var cells = rows[i];
                    int rowNum = i + 1;
                    try
                    {
                        string tag = CellStr(cells, COL_TAG);
                        if (string.IsNullOrWhiteSpace(tag)) continue;

                        string sfn = CellStr(cells, COL_SYSFN);
                        IComosDCDevice baseObj = null;
                        if (!string.IsNullOrWhiteSpace(sfn))
                            baseBySFN.TryGetValue(sfn, out baseObj);

                        object mainObj = null;
                        if (objByTag.ContainsKey(tag))
                            mainObj = objByTag[tag];
                        else if (baseObj != null)
                        {
                            mainObj = qsGlobal.GetOrCreateObject(docObj, tag, baseObj, null);
                            if (mainObj != null) objByTag[tag] = mainObj;
                        }

                        if (mainObj == null) continue;

                        var mainDev = mainObj as IComosDDevice;
                        if (mainDev == null) continue;

                        // Usar alvo de conexão correto (contato se contator, senão o próprio)
                        IComosDDevice connDev;
                        if (!connTargetByTag.TryGetValue(tag, out connDev))
                            connDev = mainDev;

                        // ── ConnDe: EB02 do "De" → EB01 do principal (ou contato) ──
                        string deTag = CellStr(cells, COL_CONN_DE);
                        if (!string.IsNullOrWhiteSpace(deTag) && deTag.ToUpper() != "N/A")
                        {
                            try
                            {
                                // Verificar se esta conexão já foi feita (evitar duplicata)
                                string pairKeyDe = deTag + "→" + tag;
                                string pairKeyDeRev = tag + "→" + deTag;
                                if (connectedPairs.Contains(pairKeyDe) || connectedPairs.Contains(pairKeyDeRev))
                                    goto skipConnDe;

                                // Resolver alvo de conexão do "de" (pode ser contato de outro contator)
                                IComosDDevice deConnDev;
                                if (!connTargetByTag.TryGetValue(deTag, out deConnDev))
                                {
                                    // Fallback: buscar em objByTag em vez de criar novo objeto
                                    object deObj;
                                    if (objByTag.TryGetValue(deTag, out deObj))
                                        deConnDev = deObj as IComosDDevice;
                                }

                                if (deConnDev != null)
                                {
                                    var conFromDe = GetConnectorOrLike(deConnDev, PIN_OUT, globalUtilities);
                                    var conMain   = GetConnector(connDev, PIN_IN);
                                    if (conFromDe != null && conMain != null)
                                    {
                                        conMain.Connect(conFromDe);
                                        connCount++;
                                        connectedPairs.Add(pairKeyDe);
                                    }
                                }
                                skipConnDe:;
                            }
                            catch (Exception ex)
                            {
                                errors.Add(string.Format("Row {0} ConnDe error: {1}", rowNum, ex.Message));
                            }
                        }

                        // ── ConnPara: EB01 do "Para" → EB02 do principal (ou contato) ──
                        string paraTag = CellStr(cells, COL_CONN_PARA);
                        if (!string.IsNullOrWhiteSpace(paraTag) && paraTag.ToUpper() != "N/A")
                        {
                            try
                            {
                                // Verificar se esta conexão já foi feita (evitar duplicata)
                                string pairKeyPara = tag + "→" + paraTag;
                                string pairKeyParaRev = paraTag + "→" + tag;
                                if (connectedPairs.Contains(pairKeyPara) || connectedPairs.Contains(pairKeyParaRev))
                                    goto skipConnPara;

                                // Resolver alvo de conexão do "para" (pode ser contato de outro contator)
                                IComosDDevice paraConnDev;
                                if (!connTargetByTag.TryGetValue(paraTag, out paraConnDev))
                                {
                                    // Fallback: buscar em objByTag em vez de criar novo objeto
                                    object paraObj;
                                    if (objByTag.TryGetValue(paraTag, out paraObj))
                                        paraConnDev = paraObj as IComosDDevice;
                                }

                                if (paraConnDev != null)
                                {
                                    var conFromPara = GetConnectorOrLike(paraConnDev, PIN_IN, globalUtilities);

                                    string pinPrincipal = PIN_OUT;
                                    try
                                    {
                                        IComosDCDevice cdev = connDev.CDevice;
                                        if (cdev != null && cdev.SystemFullName() == GROUND_SFN)
                                            pinPrincipal = PIN_IN;
                                    }
                                    catch { }

                                    var conMain = GetConnector(connDev, pinPrincipal);
                                    if (conFromPara != null && conMain != null)
                                    {
                                        conMain.Connect(conFromPara);
                                        connCount++;
                                        connectedPairs.Add(pairKeyPara);
                                    }
                                }
                                skipConnPara:;
                            }
                            catch (Exception ex)
                            {
                                errors.Add(string.Format("Row {0} ConnPara error: {1}", rowNum, ex.Message));
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        errors.Add(string.Format("Row {0} connection error: {1}", rowNum, ex.Message));
                    }
                }

                // ═══════════════════════════════════════════════════════
                // PASSO 4 — Desenhar bobinas que têm conexões mas não
                //           foram desenhadas (safety net)
                // ═══════════════════════════════════════════════════════
                if (coilObjByTag.Count > 0)
                {
                    dynamic reportCoil = null;
                    try
                    {
                        var docCoil = docObj as IComosDDocument;
                        if (docCoil == null)
                        {
                            errors.Add("PASSO 4 SKIP: docObj is not IComosDDocument — coil drawing skipped.");
                        }
                        else
                        {
                            reportCoil = docCoil.Report();
                            if (reportCoil != null)
                            {
                                reportCoil.Open();
                                dynamic repDocCoil = reportCoil.ReportDocument;

                                foreach (var kvp in coilObjByTag)
                                {
                                    if (coilDrawnTags.Contains(kvp.Key)) continue;

                                    IComosDDevice coilDev = kvp.Value;

                                    // Verificar se a bobina tem conexões
                                    bool hasConn = false;
                                    var conIn  = GetConnector(coilDev, PIN_IN);
                                    var conOut = GetConnector(coilDev, PIN_OUT);
                                    try { if (conIn  != null && conIn.ConnectedWith()  != null) hasConn = true; } catch { }
                                    try { if (!hasConn && conOut != null && conOut.ConnectedWith() != null) hasConn = true; } catch { }

                                    if (!hasConn) continue;

                                    // Verificar se já tem símbolo no diagrama
                                    bool alreadyDrawn = false;
                                    try
                                    {
                                        var bpDocs = coilDev.BackPointerDocObjs();
                                        if (bpDocs != null && bpDocs.Count() > 0) alreadyDrawn = true;
                                    }
                                    catch { }

                                    if (alreadyDrawn) continue;

                                    // Posicionar perto do contato (offset Y +30mm)
                                    double coilX = 100, coilY = 130;
                                    if (contactObjByTag.ContainsKey(kvp.Key))
                                    {
                                        foreach (var di in toDraw)
                                        {
                                            if (di.Tag == kvp.Key + CONTATO_CHILD_NAME_SUFFIX)
                                            {
                                                coilX = di.X;
                                                coilY = di.Y + 30;
                                                break;
                                            }
                                        }
                                    }

                                    try
                                    {
                                        IComosDCDevice coilBase;
                                        baseBySFN.TryGetValue(CONTATOR_SFN, out coilBase);
                                        if (coilBase != null)
                                        {
                                            try { qsGlobal.CDeviceChange(coilDev, coilBase); } catch { }
                                            try { coilDev.CDevice = coilBase; } catch { }
                                        }

                                        dynamic ro = repDocCoil.CreateReportObject(coilX, coilY, coilX, coilY);
                                        ro.CreateXObj("ComosWspRoDevice.WspRoDevice");
                                        var gcCoil = new Comos.WSP.RoUtilities.GlobalCastings();
                                        IRoDevice iroCoil = gcCoil.GC_GetIRODevice((object)ro);
                                        iroCoil.Determination = DeterminationLevel.C_DL_Fix;
                                        iroCoil.Device = coilDev;
                                        // Do NOT save per-coil — batch save once after loop
                                        drawnCount++;
                                        coilDrawnTags.Add(kvp.Key);
                                    }
                                    catch (Exception ex)
                                    {
                                        errors.Add(string.Format("Coil draw '{0}': {1}", kvp.Key, ex.Message));
                                    }
                                }

                                // Save ONCE after all coils drawn (batch optimisation)
                                if (coilDrawnTags.Count > 0)
                                    reportCoil.Save();
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        errors.Add("Coil safety draw error: " + ex.Message);
                    }
                }

                // ── Montar resultado ──
                string errorSummary = errors.Count > 0 ? string.Join("; ", errors) : "";
                return new
                {
                    success     = true,
                    created     = createdCount,
                    drawn       = drawnCount,
                    connections = connCount,
                    skipped     = skipCount,
                    errorCount  = errors.Count,
                    errors      = errorSummary,
                    message     = string.Format(
                        "Import complete: {0} objects created, {1} positioned on diagram at XY coordinates, {2} connections made.{3}",
                        createdCount, drawnCount, connCount,
                        errors.Count > 0 ? string.Format(" {0} errors occurred.", errors.Count) : "")
                };
            }
            finally
            {
                try { if (globalCastings != null) Marshal.ReleaseComObject(globalCastings); } catch { }
                try { if (globalUtilities != null) Marshal.ReleaseComObject(globalUtilities); } catch { }
            }
        }

        // ====================================================================
        // SIMPLE JSON field extractor (no external dependencies)
        // ====================================================================
        private static string JsonStr(string json, string field)
        {
            // Matches "field":"value" or "field": "value" (handles escaped quotes)
            var m = System.Text.RegularExpressions.Regex.Match(json,
                "\"" + field + "\"\\s*:\\s*\"((?:[^\"\\\\]|\\\\.)*)\"");
            return m.Success ? m.Groups[1].Value.Replace("\\\"", "\"").Replace("\\\\", "\\") : null;
        }
        private static double JsonNum(string json, string field)
        {
            var m = System.Text.RegularExpressions.Regex.Match(json,
                "\"" + field + "\"\\s*:\\s*([\\d.\\-]+)");
            double v;
            return m.Success && double.TryParse(m.Groups[1].Value,
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out v) ? v : 0;
        }

        // ── Internal overload: called from ImportEquipmentFromExcel when __INLINE__ prefix detected ──
        private object DrawSingleObject(string documentUID, int documentType, string json)
        {
            string tag         = JsonStr(json, "tag");
            string description = JsonStr(json, "description");
            string sfn         = JsonStr(json, "systemFullName");
            double x           = JsonNum(json, "x");
            double y           = JsonNum(json, "y");
            return DrawSingleObject(documentUID, documentType, tag, description, sfn, x, y);
        }

        // ── Internal overload: called from ImportEquipmentFromExcel when __CONNECT__ prefix detected ──
        private object ConnectObjects(string documentUID, int documentType, string json)
        {
            string sourceTag = JsonStr(json, "sourceTag");
            string targetTag = JsonStr(json, "targetTag");
            string sourceSFN = JsonStr(json, "sourceSFN");
            string targetSFN = JsonStr(json, "targetSFN");
            return ConnectObjects(documentUID, documentType, sourceTag, targetTag, sourceSFN, targetSFN);
        }

        // ====================================================================
        // DRAW SINGLE OBJECT — Interactive Drawing via chat
        //
        // Creates ONE equipment object on a COMOS diagram at specified
        // coordinates. Used by the Interactive Drawing chat feature.
        // ====================================================================

        [AiFunction(
            "draw_single_object",
            "Creates a single equipment object on a COMOS diagram at specified " +
            "XY coordinates. Used for interactive, one-at-a-time drawing via " +
            "the chat interface. Resolves the COMOS base object from the " +
            "SystemFullName, creates or retrieves the device, sets the " +
            "description, and draws it on the diagram.")]
        public object DrawSingleObject(
            [DescribeParameter(
                "SystemUID of the target COMOS document (diagram) to draw on",
                ExampleValue = "A5B4Z726ZU")]
            string documentUID,

            [DescribeParameter(
                "Document type number in COMOS (usually 29 for electrical/P&ID diagrams)",
                ExampleValue = "29")]
            int documentType,

            [DescribeParameter(
                "Equipment tag name, e.g. '=M01.Q01'",
                ExampleValue = "=M01.Q01")]
            string tag,

            [DescribeParameter(
                "Equipment description, e.g. 'Motor 3-phase'",
                ExampleValue = "Motor 3-phase")]
            string description,

            [DescribeParameter(
                "COMOS SystemFullName for the base object (from system_matcher), " +
                "e.g. '@30|M41|A50|A10|A20|A20|A20|A10'",
                ExampleValue = "@30|M41|A50|A10|A20|A20|A20|A10")]
            string systemFullName,

            [DescribeParameter(
                "X coordinate (mm) on the diagram",
                ExampleValue = "100")]
            double x,

            [DescribeParameter(
                "Y coordinate (mm) on the diagram",
                ExampleValue = "200")]
            double y)
        {
            if (Workset == null)
                return new { success = false, error = "Workset not available. COMOS must be running." };

            if (string.IsNullOrWhiteSpace(systemFullName))
                return new { success = false, error = "systemFullName is required." };

            if (string.IsNullOrWhiteSpace(tag))
                return new { success = false, error = "tag is required." };

            // Resolve document — "ACTIVE" means use currently opened drawing
            string resolvedDocUID = (documentUID ?? "").Trim();
            bool isActiveMode = string.IsNullOrWhiteSpace(resolvedDocUID) || resolvedDocUID.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase);
            object activeDocObj = null;

            if (isActiveMode)
            {
                string activeError;
                activeDocObj = GetActiveDocument(out activeError);
                if (activeDocObj == null)
                    return new { success = false, error = activeError ?? "No document is currently open in COMOS. Please open the target drawing (P&ID or Diagram) before drawing objects." };
                try { resolvedDocUID = ((dynamic)activeDocObj).SystemUID; } catch { resolvedDocUID = "ACTIVE"; }
            }

            dynamic globalCastings = null;
            dynamic report = null;

            try
            {
                // 1. Load the document — use active doc directly, or resolve by UID/Name
                object docObj = activeDocObj ?? ResolveDocument(documentType, resolvedDocUID);
                if (docObj == null)
                    return new { success = false, error = "Document not found: " + resolvedDocUID + ". Please open the target drawing in COMOS before using interactive mode." };

                // 2. Get project and resolve CDevice base object
                var project = Workset.GetCurrentProject();
                if (project == null)
                    return new { success = false, error = "No project is currently open." };

                IComosDCDevice baseObj = project.GetCDeviceBySystemFullname(systemFullName, 3);
                if (baseObj == null)
                    return new { success = false, error = "Base object not found for SystemFullName: " + systemFullName };

                // Confirm the resolved CDevice SystemFullName matches
                string resolvedBaseObjSFN = "";
                try { resolvedBaseObjSFN = baseObj.SystemFullName(); }
                catch { resolvedBaseObjSFN = "(error reading SFN)"; }

                // 3. Create or retrieve the logical device
                _QsGlobalObj qsGlobal = (_QsGlobalObj)(new QsGlobalObjClass());
                object deviceObj = qsGlobal.GetOrCreateObject(docObj, tag, baseObj, null);
                if (deviceObj == null)
                    return new { success = false, error = "GetOrCreateObject returned null for tag: " + tag };

                var dev = deviceObj as IComosDDevice;

                // ── Diagnostics: read CDevice BEFORE any fix ──
                string cdevBeforeFix = "(no dev)";
                if (dev != null)
                {
                    try
                    {
                        var cd = dev.CDevice;
                        cdevBeforeFix = (cd != null) ? cd.SystemFullName() : "(null)";
                    }
                    catch (Exception ex) { cdevBeforeFix = "(error: " + ex.Message + ")"; }
                }

                // ── Force CDevice to the intended base object ──
                // Method 1: qsGlobal.CDeviceChange (API specifically designed for this)
                string cdevChangeResult = "";
                if (dev != null)
                {
                    try
                    {
                        IComosDCDevice newCD = qsGlobal.CDeviceChange(dev, baseObj);
                        cdevChangeResult = (newCD != null)
                            ? "CDeviceChange OK → " + newCD.SystemFullName()
                            : "CDeviceChange returned null";
                    }
                    catch (Exception ex)
                    {
                        cdevChangeResult = "CDeviceChange error: " + ex.Message;
                    }
                }

                // Method 2: Direct property set as fallback
                string directSetResult = "";
                if (dev != null)
                {
                    try
                    {
                        dev.CDevice = baseObj;
                        directSetResult = "set OK";
                    }
                    catch (Exception ex)
                    {
                        directSetResult = "set error: " + ex.Message;
                    }
                }

                // ── Diagnostics: read CDevice AFTER fix ──
                string cdevAfterFix = "(no dev)";
                if (dev != null)
                {
                    try
                    {
                        var cd = dev.CDevice;
                        cdevAfterFix = (cd != null) ? cd.SystemFullName() : "(null)";
                    }
                    catch (Exception ex) { cdevAfterFix = "(error: " + ex.Message + ")"; }
                }

                if (dev != null && !string.IsNullOrWhiteSpace(description))
                    dev.Description = description;

                // 4. Check if already drawn
                bool alreadyDrawn = false;
                if (dev != null)
                {
                    try
                    {
                        var bpDocs = dev.BackPointerDocObjs();
                        if (bpDocs != null && bpDocs.Count() > 0)
                            alreadyDrawn = true;
                    }
                    catch { }
                }

                // 5. Draw on the diagram
                if (!alreadyDrawn)
                {
                    var gcObj = new Comos.WSP.RoUtilities.GlobalCastings();
                    globalCastings = gcObj;

                    var doc = docObj as IComosDDocument;
                    report = doc.Report();
                    report.Open();
                    dynamic repDoc = report.ReportDocument;

                    dynamic ro = repDoc.CreateReportObject(x, y, x, y);
                    ro.CreateXObj("ComosWspRoDevice.WspRoDevice");

                    // Use the typed GlobalCastings.GC_GetIRODevice which returns
                    // ComosVBInterface.IRoDevice — the exact interface VBScript uses.
                    IRoDevice iroDev = gcObj.GC_GetIRODevice((object)ro);
                    iroDev.Determination = DeterminationLevel.C_DL_Fix;
                    iroDev.Device = dev;

                    report.Save();
                }

                // Fully commit device to the DB so connect_objects can find it
                // via strict document hierarchy (DevObjects) on the next call.
                try { dev.Save(); } catch { }
                try { Workset.SaveAll(); } catch { }

                return new
                {
                    success           = true,
                    tag               = tag,
                    description       = description,
                    systemFullName    = systemFullName,
                    resolvedBaseObj   = resolvedBaseObjSFN,
                    cdevBeforeFix     = cdevBeforeFix,
                    cdevChangeResult  = cdevChangeResult,
                    directSetResult   = directSetResult,
                    cdevAfterFix      = cdevAfterFix,
                    x                 = x,
                    y                 = y,
                    documentUID       = resolvedDocUID,
                    alreadyDrawn      = alreadyDrawn,
                    message           = string.Format(
                        "Object '{0}' {1} at ({2}, {3}). BaseObj requested: {4}. CDevice before: {5} → after: {6}. CDeviceChange: {7}. DirectSet: {8}",
                        tag,
                        alreadyDrawn ? "already existed" : "created and drawn",
                        x, y,
                        resolvedBaseObjSFN,
                        cdevBeforeFix,
                        cdevAfterFix,
                        cdevChangeResult,
                        directSetResult)
                };
            }
            catch (Exception ex)
            {
                return new
                {
                    success = false,
                    tag     = tag,
                    error   = "DrawSingleObject error: " + ex.Message,
                    stack   = ex.StackTrace
                };
            }
            finally
            {
                // Do NOT close the report — keep diagram open for subsequent draws.
                // The user will close it manually or via "done"/"pronto".
                // try { if (report != null) report.Close(); } catch { }
                try { if (globalCastings != null) Marshal.ReleaseComObject(globalCastings); } catch { }
            }
        }

        // ====================================================================
        // SCAN DOCUMENT TAGS — Diagnostic: list tags visible on a document
        // ====================================================================

        [AiFunction(
            "scan_document_tags",
            "Diagnostic tool: scans a COMOS document and returns the Name, Label, and SystemUID " +
            "of every device object found on it. Use this to verify which tags exist before connecting.")]
        public object ScanDocumentTags(
            [DescribeParameter("SystemUID or name of the COMOS document to scan (use 'ACTIVE' for the currently open one)", ExampleValue = "FA.020")]
            string documentUID,
            [DescribeParameter("Document type (29 for electrical/P&ID diagrams)", ExampleValue = "29")]
            int documentType,
            [DescribeParameter("Maximum number of tags to return (default 60)", ExampleValue = "60")]
            int maxTags)
        {
            if (Workset == null)
                return new { success = false, error = "Workset not available." };

            if (maxTags <= 0) maxTags = 60;

            string resolvedUID = (documentUID ?? "").Trim();
            bool isActive = string.IsNullOrWhiteSpace(resolvedUID) || resolvedUID.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase);
            object docObj = null;

            if (isActive)
            {
                string activeError;
                docObj = GetActiveDocument(out activeError);
                if (docObj == null)
                    return new { success = false, error = activeError ?? "No active document." };
                try { resolvedUID = ((dynamic)docObj).SystemUID; } catch { resolvedUID = "ACTIVE"; }
            }
            else
            {
                docObj = ResolveDocument(documentType, resolvedUID);
                if (docObj == null)
                    return new { success = false, error = "Document not found: " + resolvedUID };
            }

            var results = new List<string>();
            string docUID = TryGetStringProperty(docObj, "SystemUID");

            try
            {
                dynamic dynDoc = docObj;

                // Path A: scan Owner DevObjects tree (direct hierarchy children)
                try
                {
                    dynamic owner = dynDoc.Owner;
                    if (owner != null) CollectTagInfo(owner, results, maxTags, 0);
                }
                catch { }

                // Path B: scan docObj DevObjects directly
                if (results.Count < maxTags)
                {
                    try { CollectTagInfo(dynDoc, results, maxTags, 0); }
                    catch { }
                }

                // Path C: scan ALL devices in the project, filter by BackPointerDocObjs
                // This finds devices placed on the diagram but owned by different hierarchy branches
                // (which DevObjects traversal would miss — the most common case in COMOS electrical diagrams)
                if (results.Count < maxTags)
                {
                    try
                    {
                        var project = Workset.GetCurrentProject();
                        if (project != null && !string.IsNullOrWhiteSpace(docUID))
                        {
                            dynamic allDevs = ((dynamic)project).AllDevices();
                            if (allDevs != null)
                            {
                                int devCount = allDevs.Count;
                                for (int i = 1; i <= devCount && results.Count < maxTags; i++)
                                {
                                    try
                                    {
                                        dynamic dev = allDevs.Item(i);
                                        if (dev == null) continue;

                                        bool placedOnDoc = false;
                                        try
                                        {
                                            dynamic bpDocs = dev.BackPointerDocObjs;
                                            if (bpDocs != null)
                                            {
                                                int bpCount = bpDocs.Count;
                                                for (int j = 1; j <= bpCount && !placedOnDoc; j++)
                                                {
                                                    try
                                                    {
                                                        dynamic bpItem = bpDocs.Item(j);
                                                        if (bpItem == null) continue;
                                                        string bpUID = TryGetStringProperty(bpItem, "SystemUID");
                                                        if (docUID.Equals(bpUID, StringComparison.OrdinalIgnoreCase))
                                                        { placedOnDoc = true; break; }
                                                        try
                                                        {
                                                            dynamic bpOwner = bpItem.Owner;
                                                            if (bpOwner != null)
                                                            {
                                                                string owUID = TryGetStringProperty(bpOwner, "SystemUID");
                                                                if (docUID.Equals(owUID, StringComparison.OrdinalIgnoreCase))
                                                                { placedOnDoc = true; break; }
                                                            }
                                                        }
                                                        catch { }
                                                    }
                                                    catch { continue; }
                                                }
                                            }
                                        }
                                        catch { }

                                        if (!placedOnDoc) continue;

                                        string name = "", label = "", uid = "", sfn = "";
                                        try { name = (string)dev.Name ?? ""; } catch { }
                                        try { label = (string)dev.Label ?? ""; } catch { }
                                        try { uid = (string)dev.SystemUID ?? ""; } catch { }
                                        try { sfn = (string)dev.SystemFullName ?? ""; } catch { }

                                        string entry = "[Name=" + name + ", Label=" + label + ", UID=" + uid + ", SFN=" + sfn + ", via=BackPointer]";
                                        if (!results.Contains(entry) &&
                                            (!string.IsNullOrWhiteSpace(name) || !string.IsNullOrWhiteSpace(label)))
                                            results.Add(entry);
                                    }
                                    catch { continue; }
                                }
                            }
                        }
                    }
                    catch { }
                }
            }
            catch (Exception ex)
            {
                return new { success = false, error = "Scan error: " + ex.Message };
            }

            return new
            {
                success = true,
                documentUID = resolvedUID,
                count = results.Count,
                tags = string.Join(" | ", results)
            };
        }

        private static void CollectTagInfo(dynamic parent, List<string> results, int maxTags, int depth)
        {
            if (depth > 8 || results.Count >= maxTags) return;
            try
            {
                dynamic devObjs = parent.DevObjects;
                if (devObjs == null) return;
                int count = devObjs.Count;
                for (int i = 1; i <= count && results.Count < maxTags; i++)
                {
                    try
                    {
                        dynamic item = devObjs.Item(i);
                        if (item == null) continue;
                        string name = "", label = "", uid = "";
                        try { name = (string)item.Name ?? ""; } catch { }
                        try { label = (string)item.Label ?? ""; } catch { }
                        try { uid = (string)item.SystemUID ?? ""; } catch { }
                        if (!string.IsNullOrWhiteSpace(name) || !string.IsNullOrWhiteSpace(label))
                            results.Add("[Name=" + name + ", Label=" + label + ", UID=" + uid + "]");
                        CollectTagInfo(item, results, maxTags, depth + 1);
                    }
                    catch { }
                }
            }
            catch { }
        }

        // ====================================================================
        // CONNECT OBJECTS — Interactive wiring via chat
        //
        // Connects two already-existing objects by their tags, using the same
        // EB01 (input) / EB02 (output) pin logic as the Excel/VBS import.
        // The connection direction is: sourceTag.EB02 → targetTag.EB01
        //   (source output feeds into target input)
        // ====================================================================

        [AiFunction(
            "connect_objects",
            "Connects two existing COMOS equipment objects by their tags, " +
            "creating an electrical/process connection. Connects the source " +
            "object output pin (EB02) to the target object input pin (EB01). " +
            "Both objects must already exist in the diagram. " +
            "Used for interactive wiring via the chat interface.")]
        public object ConnectObjects(
            [DescribeParameter(
                "SystemUID of the COMOS document (diagram) where both objects exist",
                ExampleValue = "A5B4Z726ZU")]
            string documentUID,

            [DescribeParameter(
                "Document type number in COMOS (usually 29 for electrical/P&ID diagrams)",
                ExampleValue = "29")]
            int documentType,

            [DescribeParameter(
                "Tag of the source (upstream) object — its output pin (EB02) will be used",
                ExampleValue = "=D001")]
            string sourceTag,

            [DescribeParameter(
                "Tag of the target (downstream) object — its input pin (EB01) will be used",
                ExampleValue = "=K001")]
            string targetTag,

            [DescribeParameter(
                "COMOS SystemFullName for the source object base (from system_matcher)",
                ExampleValue = "@30|M41|A50|A10|A10|A60|A70|A30")]
            string sourceSystemFullName,

            [DescribeParameter(
                "COMOS SystemFullName for the target object base (from system_matcher)",
                ExampleValue = "@30|M41|A50|A10|A10|A60|A70|A30")]
            string targetSystemFullName)
        {
            if (Workset == null)
                return new { success = false, error = "Workset not available. COMOS must be running." };

            if (string.IsNullOrWhiteSpace(sourceTag))
                return new { success = false, error = "sourceTag is required." };
            if (string.IsNullOrWhiteSpace(targetTag))
                return new { success = false, error = "targetTag is required." };

            // Resolve document — "ACTIVE" means use currently opened drawing
            string resolvedDocUID = (documentUID ?? "").Trim();
            bool isActiveMode = string.IsNullOrWhiteSpace(resolvedDocUID) || resolvedDocUID.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase);
            object activeDocObj = null;

            if (isActiveMode)
            {
                string activeError;
                activeDocObj = GetActiveDocument(out activeError);
                if (activeDocObj == null)
                    return new { success = false, error = activeError ?? "No document is currently open in COMOS. Please open the target drawing (P&ID or Diagram) before connecting objects." };
                try { resolvedDocUID = ((dynamic)activeDocObj).SystemUID; } catch { resolvedDocUID = "ACTIVE"; }
            }

            dynamic globalUtilities = null;
            _QsGlobalObj qsGlobal = null;

            try
            {
                // 1. Load document — use active doc directly, or resolve by UID/Name
                object docObj = activeDocObj ?? ResolveDocument(documentType, resolvedDocUID);
                if (docObj == null)
                    return new { success = false, error = "Document not found: " + resolvedDocUID + ". Please open the target drawing in COMOS before using interactive mode." };

                var project = Workset.GetCurrentProject();
                if (project == null)
                    return new { success = false, error = "No project is currently open." };

                try { qsGlobal = (_QsGlobalObj)(new QsGlobalObjClass()); }
                catch { qsGlobal = null; }

                IComosDCDevice sourceBase = null;
                IComosDCDevice targetBase = null;
                if (!string.IsNullOrWhiteSpace(sourceSystemFullName))
                    sourceBase = project.GetCDeviceBySystemFullname(sourceSystemFullName, 3);
                if (!string.IsNullOrWhiteSpace(targetSystemFullName))
                    targetBase = project.GetCDeviceBySystemFullname(targetSystemFullName, 3);

                IComosDCDevice fallbackBase = sourceBase ?? targetBase;
                if (fallbackBase == null)
                {
                    try
                    {
                        dynamic dynDoc = docObj;
                        dynamic owner = dynDoc.Owner;
                        if (owner != null)
                        {
                            try { fallbackBase = owner.CDevice as IComosDCDevice; }
                            catch { }

                            if (fallbackBase == null)
                            {
                                try { fallbackBase = owner as IComosDCDevice; }
                                catch { }
                            }
                        }
                    }
                    catch { }
                }

                // 2. Resolve both devices on the target document.
                string sourceTagNormalized = NormalizeTagForLookup(sourceTag);
                string targetTagNormalized = NormalizeTagForLookup(targetTag);

                // Priority 1: Strict document-owner DevObjects scan
                IComosDDevice sourceDev = FindDeviceOnDocumentStrict(docObj, sourceTagNormalized, project);
                IComosDDevice targetDev = FindDeviceOnDocumentStrict(docObj, targetTagNormalized, project);

                // Priority 2: Legacy broader search (AllDevices + BackPointerDocObjs)
                if (sourceDev == null)
                {
                    try
                    {
                        sourceDev = FindDeviceOnDocument(docObj, sourceTagNormalized, project);
                    }
                    catch { }
                }

                if (targetDev == null)
                {
                    try
                    {
                        targetDev = FindDeviceOnDocument(docObj, targetTagNormalized, project);
                    }
                    catch { }
                }

                // qs-getorcreate: for objects that exist on the document but weren't found via
                // DevObjects traversal (different hierarchy branch), GetOrCreateObject with an
                // existing tag returns the already-placed COM object in the correct document context.
                // This is preferred over AllDevices() because it returns the contextualized reference
                // that COMOS's Connect() API expects — the same object that DrawSingleObject would return.
                //
                // Attempt 1: null base (pure lookup — only succeeds if device already placed on docObj)
                // Attempt 2: fallbackBase (allows create/re-place, verified by tag match after)
                if (sourceDev == null && qsGlobal != null)
                {
                    foreach (string candidate in BuildTagCandidates(sourceTagNormalized))
                    {
                        // Try null-base first (find-only)
                        try
                        {
                            object foundObj = qsGlobal.GetOrCreateObject(docObj, candidate, null, null);
                            IComosDDevice foundDev = foundObj as IComosDDevice;
                            if (foundDev != null && DeviceMatchesTag((dynamic)foundDev, sourceTagNormalized))
                            { sourceDev = foundDev; break; }
                        }
                        catch { }
                        if (sourceDev != null) break;

                        // Try with base (find-or-create)
                        if ((sourceBase ?? fallbackBase) != null)
                        {
                            try
                            {
                                object foundObj = qsGlobal.GetOrCreateObject(docObj, candidate, (object)(sourceBase ?? fallbackBase), null);
                                IComosDDevice foundDev = foundObj as IComosDDevice;
                                if (foundDev != null && DeviceMatchesTag((dynamic)foundDev, sourceTagNormalized))
                                { sourceDev = foundDev; break; }
                            }
                            catch { }
                        }
                        if (sourceDev != null) break;
                    }
                }

                if (targetDev == null && qsGlobal != null)
                {
                    foreach (string candidate in BuildTagCandidates(targetTagNormalized))
                    {
                        try
                        {
                            object foundObj = qsGlobal.GetOrCreateObject(docObj, candidate, null, null);
                            IComosDDevice foundDev = foundObj as IComosDDevice;
                            if (foundDev != null && DeviceMatchesTag((dynamic)foundDev, targetTagNormalized))
                            { targetDev = foundDev; break; }
                        }
                        catch { }
                        if (targetDev != null) break;

                        if ((targetBase ?? fallbackBase) != null)
                        {
                            try
                            {
                                object foundObj = qsGlobal.GetOrCreateObject(docObj, candidate, (object)(targetBase ?? fallbackBase), null);
                                IComosDDevice foundDev = foundObj as IComosDDevice;
                                if (foundDev != null && DeviceMatchesTag((dynamic)foundDev, targetTagNormalized))
                                { targetDev = foundDev; break; }
                            }
                            catch { }
                        }
                        if (targetDev != null) break;
                    }
                }

                if (sourceDev == null)
                {
                    return new
                    {
                        success = false,
                        error = "Source object '" + sourceTag + "' not found on diagram " + resolvedDocUID + ". Ensure it exists on this diagram.",
                        tried = BuildTagCandidates(sourceTagNormalized).ToArray(),
                        documentUID = resolvedDocUID,
                        strictScope = "document-owner"
                    };
                }
                if (targetDev == null)
                {
                    return new
                    {
                        success = false,
                        error = "Target object '" + targetTag + "' not found on diagram " + resolvedDocUID + ". Ensure it exists on this diagram.",
                        tried = BuildTagCandidates(targetTagNormalized).ToArray(),
                        documentUID = resolvedDocUID,
                        strictScope = "document-owner"
                    };
                }

                string sourceResolved = DescribeDeviceIdentity(sourceDev);
                string targetResolved = DescribeDeviceIdentity(targetDev);

                // 3. Get GlobalUtilities for GU_GetLikeConnector (parallel connectors)
                try
                {
                    Type guType = Type.GetTypeFromProgID("ComosROUtilities.GlobalUtilities");
                    if (guType != null) globalUtilities = Activator.CreateInstance(guType);
                }
                catch { /* parallel connectors won't be available */ }

                // 4. Connect: sourceTag.EB02 (output) → targetTag.EB01 (input)
                bool sourceConnectorCreated = false;
                bool targetConnectorCreated = false;
                var conSource = GetConnectorOrCreateLike(sourceDev, PIN_OUT, globalUtilities, out sourceConnectorCreated);
                var conTarget = GetConnectorOrCreateLike(targetDev, PIN_IN, globalUtilities, out targetConnectorCreated);

                if (conSource == null)
                    return new
                    {
                        success = false,
                        error = "Output connector (EB02) not found and could not be created on source: " + sourceTag,
                        sourceResolved = sourceResolved,
                        targetResolved = targetResolved,
                        documentUID = resolvedDocUID
                    };
                if (conTarget == null)
                    return new
                    {
                        success = false,
                        error = "Input connector (EB01) not found and could not be created on target: " + targetTag,
                        sourceResolved = sourceResolved,
                        targetResolved = targetResolved,
                        documentUID = resolvedDocUID
                    };

                conTarget.Connect(conSource);

                // Persist immediately — without SaveAll the connection object is not written to the DB.
                bool saveOk = false;
                try
                {
                    // Save the two devices plus their connectors
                    conTarget.Save();
                    conSource.Save();
                    sourceDev.Save();
                    targetDev.Save();
                    saveOk = true;
                }
                catch { /* non-fatal; connection may still be persisted on project save */ }

                try { Workset.SaveAll(); } catch { }

                // ── Auto-connect: draw the graphical pipe/line between the devices on the drawing ──
                // IXDocDeveloper.CreateConnection(IComosDConnector, IComosDConnector, IComosBaseObject)
                // is equivalent to right-click → Options → Connect Automatically in COMOS.
                // docObj is already the active XDoc (IXDocDeveloper), conTarget/conSource are the DB connectors.
                string drawDetail = "";
                try
                {
                    ComosVBInterface.IXDocDeveloper xdocDev = docObj as ComosVBInterface.IXDocDeveloper;
                    if (xdocDev != null)
                    {
                        xdocDev.CreateConnection(conTarget, conSource, null);
                        drawDetail = "IXDocDeveloper.CreateConnection OK";
                    }
                    else
                    {
                        // Fallback: try dynamic dispatch (works if docObj is a COM object implementing IXDocDeveloper)
                        dynamic dynDoc = docObj;
                        dynDoc.CreateConnection(conTarget, conSource, null);
                        drawDetail = "dynamic.CreateConnection OK";
                    }
                }
                catch (Exception exDraw)
                {
                    drawDetail = "CreateConnection failed: " + exDraw.Message;
                    // Non-fatal — logical connection is already persisted
                }

                bool isConnected = false;
                string verifyDetail = "";
                try
                {
                    object cw = conTarget.ConnectedWith();
                    if (cw == null)
                    {
                        isConnected = false;
                        verifyDetail = "target connector has no ConnectedWith after Connect (saveOk=" + saveOk + " draw=" + drawDetail + ")";
                    }
                    else
                    {
                        isConnected = IsConnectedToExpectedSource(cw, conSource, sourceDev);
                        verifyDetail = isConnected
                            ? "connected_to_expected_source (saveOk=" + saveOk + " draw=" + drawDetail + ")"
                            : "ConnectedWith() returned non-null but not to expected source (saveOk=" + saveOk + " draw=" + drawDetail + ")";
                    }
                }
                catch (Exception ex)
                {
                    verifyDetail = "verify_error: " + ex.Message + " (saveOk=" + saveOk + " draw=" + drawDetail + ")";
                }

                if (!isConnected)
                {
                    return new
                    {
                        success = false,
                        sourceTag = sourceTag,
                        targetTag = targetTag,
                        error = "Connection command executed but was not persisted.",
                        detail = verifyDetail,
                        sourceResolved = sourceResolved,
                        targetResolved = targetResolved,
                        documentUID = resolvedDocUID,
                        strictScope = "document-owner"
                    };
                }

                return new
                {
                    success    = true,
                    sourceTag  = sourceTag,
                    targetTag  = targetTag,
                    sourceConnectorCreated = sourceConnectorCreated,
                    targetConnectorCreated = targetConnectorCreated,
                    verification = verifyDetail,
                    sourceResolved = sourceResolved,
                    targetResolved = targetResolved,
                    message    = string.Format(
                        "Connected {0} (EB02) → {1} (EB01) successfully.",
                        sourceTag, targetTag),
                    documentUID = resolvedDocUID,
                    strictScope = "document-owner"
                };
            }
            catch (Exception ex)
            {
                return new
                {
                    success    = false,
                    sourceTag  = sourceTag,
                    targetTag  = targetTag,
                    error      = "ConnectObjects error: " + ex.Message,
                    stack      = ex.StackTrace
                };
            }
            finally
            {
                try { if (globalUtilities != null) Marshal.ReleaseComObject(globalUtilities); } catch { }
                try { if (qsGlobal != null) Marshal.ReleaseComObject(qsGlobal); } catch { }
            }
        }

        // ====================================================================
        // XLSX NATIVE READER — parses .xlsx as ZIP (no Excel COM needed!)
        //
        // XLSX structure:
        //   xl/sharedStrings.xml — string table (cells reference by index)
        //   xl/worksheets/sheet1.xml — cell data with row/col references
        //   xl/workbook.xml — sheet name → rId mapping
        //   xl/_rels/workbook.xml.rels — rId → file path mapping
        // ====================================================================

        /// <summary>
        /// Reads all rows from the first (or named) worksheet.
        /// Returns List of string arrays, index 0 = header row.
        /// </summary>
        private static List<string[]> ReadXlsx(string filePath, string sheetName)
        {
            var results = new List<string[]>();

            using (var zip = ZipFile.OpenRead(filePath))
            {
                // 1. Load shared strings table
                var sharedStrings = new List<string>();
                var ssEntry = zip.GetEntry("xl/sharedStrings.xml");
                if (ssEntry != null)
                {
                    using (var stream = ssEntry.Open())
                    {
                        var doc = new XmlDocument();
                        doc.Load(stream);
                        var nsMgr = new XmlNamespaceManager(doc.NameTable);
                        nsMgr.AddNamespace("s", "http://schemas.openxmlformats.org/spreadsheetml/2006/main");
                        var siNodes = doc.SelectNodes("//s:si", nsMgr);
                        if (siNodes != null)
                        {
                            foreach (XmlNode si in siNodes)
                            {
                                // Can be <t> directly or multiple <r><t> runs
                                var sb = new StringBuilder();
                                var tNodes = si.SelectNodes(".//s:t", nsMgr);
                                if (tNodes != null)
                                {
                                    foreach (XmlNode t in tNodes)
                                        sb.Append(t.InnerText);
                                }
                                sharedStrings.Add(sb.ToString());
                            }
                        }
                    }
                }

                // 2. Find sheet path — try matching by name, fallback to sheet1
                string sheetPath = FindSheetPath(zip, sheetName);

                var sheetEntry = zip.GetEntry(sheetPath);
                if (sheetEntry == null)
                {
                    // Final fallback: use the first worksheet that actually exists in the package
                    string firstExisting = FindFirstWorksheetEntryPath(zip);
                    if (!string.IsNullOrEmpty(firstExisting))
                    {
                        sheetPath = firstExisting;
                        sheetEntry = zip.GetEntry(sheetPath);
                    }
                }
                if (sheetEntry == null)
                    throw new FileNotFoundException("Worksheet not found in XLSX: " + sheetPath);

                // 3. Parse sheet XML
                using (var stream = sheetEntry.Open())
                {
                    var doc = new XmlDocument();
                    doc.Load(stream);
                    var nsMgr = new XmlNamespaceManager(doc.NameTable);
                    nsMgr.AddNamespace("s", "http://schemas.openxmlformats.org/spreadsheetml/2006/main");

                    var rowNodes = doc.SelectNodes("//s:sheetData/s:row", nsMgr);
                    if (rowNodes == null) return results;

                    // Determine max column count from first pass
                    int maxCol = 0;

                    var rawRows = new List<KeyValuePair<int, Dictionary<int, string>>>();

                    foreach (XmlNode rowNode in rowNodes)
                    {
                        int rowIdx = 0;
                        var rAttr = rowNode.Attributes["r"];
                        if (rAttr != null) int.TryParse(rAttr.Value, out rowIdx);

                        var cellMap = new Dictionary<int, string>();

                        var cellNodes = rowNode.SelectNodes("s:c", nsMgr);
                        if (cellNodes != null)
                        {
                            foreach (XmlNode cell in cellNodes)
                            {
                                string cellRef = cell.Attributes["r"] != null ? cell.Attributes["r"].Value : "";
                                int colIdx = CellRefToColIndex(cellRef);
                                if (colIdx > maxCol) maxCol = colIdx;

                                string cellType = cell.Attributes["t"] != null ? cell.Attributes["t"].Value : "";
                                var vNode = cell.SelectSingleNode("s:v", nsMgr);
                                string rawValue = vNode != null ? vNode.InnerText : "";

                                // Resolve shared string references
                                if (cellType == "s" && !string.IsNullOrEmpty(rawValue))
                                {
                                    int ssIdx;
                                    if (int.TryParse(rawValue, out ssIdx) && ssIdx >= 0 && ssIdx < sharedStrings.Count)
                                        rawValue = sharedStrings[ssIdx];
                                }
                                // Inline string
                                else if (cellType == "inlineStr")
                                {
                                    var isNode = cell.SelectSingleNode("s:is/s:t", nsMgr);
                                    rawValue = isNode != null ? isNode.InnerText : "";
                                }

                                cellMap[colIdx] = rawValue;
                            }
                        }

                        rawRows.Add(new KeyValuePair<int, Dictionary<int, string>>(rowIdx, cellMap));
                    }

                    // Convert to string arrays
                    int colCount = maxCol + 1;
                    if (colCount < 10) colCount = 10; // minimum for our expected columns

                    foreach (var kvp in rawRows)
                    {
                        var arr = new string[colCount];
                        for (int c = 0; c < colCount; c++)
                        {
                            string val;
                            arr[c] = kvp.Value.TryGetValue(c, out val) ? val : "";
                        }
                        results.Add(arr);
                    }
                }
            }

            return results;
        }

        private static List<string[]> ReadRowsFromCachedPayload(string b64)
        {
            var results = new List<string[]>();

            if (string.IsNullOrWhiteSpace(b64))
                return results;

            string text = Encoding.UTF8.GetString(Convert.FromBase64String(b64));
            var lines = text.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');

            // Header expected by importer logic:
            // A=Tag, B=Description, C=Type, D=X, E=Y, F=Page, G=From, H=To, I=SystemFullName, J=Confidence
            results.Add(new[] {
                "Tag", "Description", "Type", "X_mm", "Y_mm", "Page", "From", "To", "SystemFullName", "Confidence"
            });

            foreach (var line in lines)
            {
                if (string.IsNullOrWhiteSpace(line))
                    continue;

                var parts = line.Split('\t');
                if (parts.Length < 7)
                    continue;

                var row = new string[10];
                row[COL_TAG]       = parts[0] ?? "";
                row[COL_DESC]      = parts[1] ?? "";
                row[2]             = "";                  // type (unused)
                row[COL_X]         = parts[3] ?? "0";
                row[COL_Y]         = parts[4] ?? "0";
                row[5]             = "";                  // page (unused)
                row[COL_CONN_DE]   = parts[5] ?? "";
                row[COL_CONN_PARA] = parts[6] ?? "";
                row[COL_SYSFN]     = parts[2] ?? "";
                row[9]             = "";                  // confidence (unused)

                results.Add(row);
            }

            return results;
        }

        /// <summary>Find the internal path for a named sheet, falling back to sheet1.xml</summary>
        private static string FindSheetPath(ZipArchive zip, string sheetName)
        {
            // Try to match by name via workbook.xml + rels
            try
            {
                var wbEntry = zip.GetEntry("xl/workbook.xml");
                if (wbEntry != null)
                {
                    string targetRId = null;
                    using (var stream = wbEntry.Open())
                    {
                        var doc = new XmlDocument();
                        doc.Load(stream);
                        var nsMgr = new XmlNamespaceManager(doc.NameTable);
                        nsMgr.AddNamespace("s", "http://schemas.openxmlformats.org/spreadsheetml/2006/main");
                        var sheets = doc.SelectNodes("//s:sheets/s:sheet", nsMgr);
                        if (sheets != null)
                        {
                            foreach (XmlNode sn in sheets)
                            {
                                string name = sn.Attributes["name"] != null ? sn.Attributes["name"].Value : "";
                                if (name.Equals(sheetName, StringComparison.OrdinalIgnoreCase) ||
                                    (targetRId == null)) // first sheet as fallback
                                {
                                    var ridAttr = sn.Attributes["r:id"];
                                    if (ridAttr == null)
                                    {
                                        // Try without namespace prefix
                                        foreach (XmlAttribute a in sn.Attributes)
                                        {
                                            if (a.LocalName == "id") { ridAttr = a; break; }
                                        }
                                    }
                                    if (ridAttr != null)
                                    {
                                        targetRId = ridAttr.Value;
                                        if (name.Equals(sheetName, StringComparison.OrdinalIgnoreCase))
                                            break; // exact match
                                    }
                                }
                            }
                        }
                    }

                    if (targetRId != null)
                    {
                        var relsEntry = zip.GetEntry("xl/_rels/workbook.xml.rels");
                        if (relsEntry != null)
                        {
                            using (var stream = relsEntry.Open())
                            {
                                var doc = new XmlDocument();
                                doc.Load(stream);
                                foreach (XmlNode rel in doc.DocumentElement.ChildNodes)
                                {
                                    if (rel.Attributes != null && rel.Attributes["Id"] != null &&
                                        rel.Attributes["Id"].Value == targetRId)
                                    {
                                        string target = rel.Attributes["Target"].Value;
                                        return NormalizeWorksheetTarget(target);
                                    }
                                }
                            }
                        }
                    }
                }
            }
            catch { /* fall through to default */ }

            // Default: first worksheet entry that exists in the ZIP
            string first = FindFirstWorksheetEntryPath(zip);
            if (!string.IsNullOrEmpty(first))
                return first;

            // Legacy fallback (kept for compatibility)
            return "xl/worksheets/sheet1.xml";
        }

        private static string NormalizeWorksheetTarget(string target)
        {
            if (string.IsNullOrWhiteSpace(target))
                return target;

            string normalized = target.Replace('\\', '/').Trim();

            // Relationship targets may come as:
            //   worksheets/sheet1.xml
            //   /xl/worksheets/sheet1.xml
            //   xl/worksheets/sheet1.xml
            if (normalized.StartsWith("/"))
                normalized = normalized.Substring(1);

            if (normalized.StartsWith("xl/", StringComparison.OrdinalIgnoreCase))
                return normalized;

            if (normalized.StartsWith("worksheets/", StringComparison.OrdinalIgnoreCase))
                return "xl/" + normalized;

            // Generic relative target from workbook.xml.rels is relative to xl/
            return "xl/" + normalized;
        }

        private static string FindFirstWorksheetEntryPath(ZipArchive zip)
        {
            foreach (var e in zip.Entries)
            {
                var name = e.FullName.Replace('\\', '/');
                if (name.StartsWith("xl/worksheets/", StringComparison.OrdinalIgnoreCase) &&
                    name.EndsWith(".xml", StringComparison.OrdinalIgnoreCase))
                {
                    return name;
                }
            }
            return null;
        }

        private static bool TryExtractPayload(string input, string[] prefixes, out string payload)
        {
            payload = null;
            if (string.IsNullOrWhiteSpace(input) || prefixes == null)
                return false;

            string s = input.Trim();
            for (int i = 0; i < prefixes.Length; i++)
            {
                string p = prefixes[i];
                if (string.IsNullOrEmpty(p)) continue;
                if (s.StartsWith(p, StringComparison.OrdinalIgnoreCase))
                {
                    payload = s.Substring(p.Length);
                    return true;
                }
            }
            return false;
        }

        private static bool TryExtractInlineJson(string input, out string json)
        {
            json = null;
            if (string.IsNullOrWhiteSpace(input)) return false;

            string s = input.Trim();
            int i = s.IndexOf('{');
            if (i < 0) return false;

            string candidate = s.Substring(i).Trim();
            if (candidate.Contains("\"tag\"") &&
                candidate.Contains("\"systemFullName\"") &&
                candidate.Contains("\"x\"") &&
                candidate.Contains("\"y\""))
            {
                json = candidate;
                return true;
            }
            return false;
        }

        private static bool TryExtractConnectJson(string input, out string json)
        {
            json = null;
            if (string.IsNullOrWhiteSpace(input)) return false;

            string s = input.Trim();
            int i = s.IndexOf('{');
            if (i < 0) return false;

            string candidate = s.Substring(i).Trim();
            if (candidate.Contains("\"sourceTag\"") &&
                candidate.Contains("\"targetTag\""))
            {
                json = candidate;
                return true;
            }
            return false;
        }

        private static string TryDecodeBase64(string b64)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(b64)) return null;
                return Encoding.UTF8.GetString(Convert.FromBase64String(b64.Trim()));
            }
            catch
            {
                return null;
            }
        }

        /// <summary>Converts an Excel cell reference like "C5" to a 0-based column index (2)</summary>
        private static int CellRefToColIndex(string cellRef)
        {
            int col = 0;
            for (int i = 0; i < cellRef.Length; i++)
            {
                char c = cellRef[i];
                if (c >= 'A' && c <= 'Z')
                    col = col * 26 + (c - 'A' + 1);
                else if (c >= 'a' && c <= 'z')
                    col = col * 26 + (c - 'a' + 1);
                else
                    break; // hit a digit, done with column letters
            }
            return col - 1; // 0-based
        }

