        /// <summary>Info para batch-drawing de objetos no diagrama</summary>
        private class DrawInfo
        {
            public string Tag;
            public object DeviceObj;
            public IComosDDevice Device;      // typed ref (avoids late cast)
            public IComosDCDevice BaseObj;     // for re-forcing CDevice before draw
            public double X;
            public double Y;
        }

        /// <summary>Verifica se a descrição indica bobina de contator.</summary>
        private static bool IsCoilDescription(string desc)
        {
            if (string.IsNullOrWhiteSpace(desc)) return false;
            string lower = desc.ToLowerInvariant();
            return lower.Contains("bobina de contator") ||
                   lower.Contains("bobina") ||
                   lower.Contains("coil");
        }

        /// <summary>Cria ou recupera contato filho sob um contator.</summary>
        private static IComosDDevice GetOrCreateChildContact(
            IComosDDevice parent, IComosDCDevice childBase, string childName)
        {
            // Verificar se o filho já existe
            try
            {
                dynamic dynParent = parent;
                dynamic devObjs = dynParent.DevObjects;
                if (devObjs != null)
                {
                    int count = devObjs.Count;
                    for (int idx = 1; idx <= count; idx++)
                    {
                        dynamic item = devObjs.Item(idx);
                        if (item != null)
                        {
                            string name = (string)item.Name;
                            if (name == childName)
                                return item as IComosDDevice;
                        }
                    }
                }
            }
            catch { /* DevObjects pode não estar disponível */ }

            // Criar novo filho
            try
            {
                dynamic dynP = parent;
                object child = dynP.CreateDevObj(childName, childBase);
                return child as IComosDDevice;
            }
            catch { return null; }
        }

        /// <summary>
        /// Get the currently active/opened document in COMOS.
        /// Comprehensive approach: tries COM interface casts, dynamic dispatch,
        /// assembly scanning for Application singletons, and ROT lookup.
        /// Returns the document object or null (with diagnostic error message).
        /// </summary>
        private object GetActiveDocument(out string errorMessage)
        {
            errorMessage = null;
            var diag = new StringBuilder();
            diag.AppendLine("[GetActiveDocument v3 diagnostics]");
            diag.AppendLine("Workset type: " + (Workset == null ? "null" : Workset.GetType().FullName));

            // ── Approach 1: Cast Workset COM object to IAppCooperate ──
            // The underlying COM RCW might implement multiple interfaces via QueryInterface
            try
            {
                diag.Append("1. Workset as IAppCooperate: ");
                IAppCooperate appCoop = Workset as IAppCooperate;
                if (appCoop != null)
                {
                    diag.AppendLine("OK");
                    object doc = TryGetDocFromAppCooperate(appCoop, diag, "1");
                    if (doc != null) return doc;
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 2: Cast Workset to IApplication ──
            try
            {
                diag.Append("2. Workset as IApplication: ");
                IApplication app = Workset as IApplication;
                if (app != null)
                {
                    diag.AppendLine("OK");
                    try
                    {
                        dynamic dynApp = app;
                        object xdoc = dynApp.ActiveXDoc();
                        if (xdoc != null)
                        {
                            object doc = TryGetDocFromXDoc(xdoc, diag, "2");
                            if (doc != null) return doc;
                        }
                    }
                    catch (Exception ex2) { diag.AppendLine("  2b. dynApp.ActiveXDoc ERR: " + ex2.Message); }
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 3: Dynamic dispatch — ActiveXDoc() directly on Workset ──
            try
            {
                diag.Append("3a. dynamic Workset.ActiveXDoc(): ");
                dynamic ws = Workset;
                object xdoc = ws.ActiveXDoc();
                if (xdoc != null)
                {
                    diag.AppendLine("OK, type=" + xdoc.GetType().FullName);
                    object doc = TryGetDocFromXDoc(xdoc, diag, "3a");
                    if (doc != null) return doc;
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 3b: Dynamic Workset.Application → ActiveXDoc() ──
            try
            {
                diag.Append("3b. dynamic Workset.Application: ");
                dynamic ws = Workset;
                object appObj = ws.Application;
                if (appObj != null)
                {
                    diag.AppendLine("OK, type=" + appObj.GetType().FullName);
                    // Try IAppCooperate cast on the Application object
                    try
                    {
                        IAppCooperate ac = appObj as IAppCooperate;
                        if (ac != null)
                        {
                            diag.AppendLine("  3b. AppObj as IAppCooperate: OK");
                            object doc = TryGetDocFromAppCooperate(ac, diag, "3b");
                            if (doc != null) return doc;
                        }
                    }
                    catch { }
                    // Dynamic ActiveXDoc on the Application object
                    try
                    {
                        dynamic dynApp = appObj;
                        object xdoc = dynApp.ActiveXDoc();
                        if (xdoc != null)
                        {
                            object doc = TryGetDocFromXDoc(xdoc, diag, "3b-dyn");
                            if (doc != null) return doc;
                        }
                    }
                    catch (Exception ex2) { diag.AppendLine("  3b-dyn ERR: " + ex2.Message); }
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 3c: Dynamic Workset.GetApplication() ──
            try
            {
                diag.Append("3c. dynamic Workset.GetApplication(): ");
                dynamic ws = Workset;
                object appObj = ws.GetApplication();
                if (appObj != null)
                {
                    diag.AppendLine("OK, type=" + appObj.GetType().FullName);
                    IAppCooperate ac = appObj as IAppCooperate;
                    if (ac != null)
                    {
                        object doc = TryGetDocFromAppCooperate(ac, diag, "3c");
                        if (doc != null) return doc;
                    }
                    try
                    {
                        dynamic dynApp = appObj;
                        object xdoc = dynApp.ActiveXDoc();
                        if (xdoc != null)
                        {
                            object doc = TryGetDocFromXDoc(xdoc, diag, "3c-dyn");
                            if (doc != null) return doc;
                        }
                    }
                    catch (Exception ex2) { diag.AppendLine("  3c-dyn ERR: " + ex2.Message); }
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 3d: Dynamic Workset.Custom / Workset.Globals ──
            foreach (string propName in new[] { "Custom", "Globals", "ActiveDocument", "CurrentDocument", "XDoc" })
            {
                try
                {
                    diag.Append("3d. dynamic Workset." + propName + ": ");
                    dynamic ws = Workset;
                    object val = ws.GetType().InvokeMember(propName,
                        BindingFlags.GetProperty | BindingFlags.InvokeMethod | BindingFlags.Public | BindingFlags.Instance,
                        null, ws, null);
                    if (val != null)
                    {
                        diag.AppendLine("OK, type=" + val.GetType().FullName);
                        // Could be a document directly
                        try
                        {
                            int sysType = (int)((dynamic)val).SystemType;
                            if (sysType == 29 || sysType == 30 || sysType == 31 || sysType == 32)
                                return val;
                        }
                        catch { }
                        // Could have ActiveXDoc
                        try
                        {
                            dynamic dynVal = val;
                            object xdoc = dynVal.ActiveXDoc();
                            if (xdoc != null)
                            {
                                object doc = TryGetDocFromXDoc(xdoc, diag, "3d-" + propName);
                                if (doc != null) return doc;
                            }
                        }
                        catch { }
                    }
                    else { diag.AppendLine("null"); }
                }
                catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }
            }

            // ── Approach 4: SelectedObject via dynamic dispatch (original) ──
            try
            {
                diag.Append("4. dynamic Workset.SelectedObject: ");
                dynamic ws = Workset;
                object selectedObj = ws.SelectedObject;
                if (selectedObj != null)
                {
                    diag.AppendLine("OK, type=" + selectedObj.GetType().FullName);
                    try
                    {
                        dynamic selDyn = selectedObj;
                        int sysType = (int)selDyn.SystemType;
                        diag.AppendLine("  4. SystemType=" + sysType);
                        if (sysType == 29 || sysType == 30 || sysType == 31 || sysType == 32)
                            return selectedObj;
                    }
                    catch (Exception ex2) { diag.AppendLine("  4-sysType ERR: " + ex2.Message); }
                    try
                    {
                        dynamic selDyn = selectedObj;
                        dynamic docs = selDyn.Documents;
                        if (docs != null)
                        {
                            int cnt = (int)docs.Count;
                            diag.AppendLine("  4. Documents.Count=" + cnt);
                            if (cnt > 0) return docs.Item(1);
                        }
                    }
                    catch (Exception ex2) { diag.AppendLine("  4-docs ERR: " + ex2.Message); }
                    try
                    {
                        string uid = (string)((dynamic)selectedObj).SystemUID;
                        if (!string.IsNullOrEmpty(uid))
                        {
                            object doc = Workset.LoadObjectByType(29, uid);
                            if (doc != null) return doc;
                        }
                    }
                    catch { }
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 5: Scan loaded assemblies for IAppCooperate / IApplication singletons ──
            try
            {
                diag.Append("5. Assembly scan: ");
                var assemblies = AppDomain.CurrentDomain.GetAssemblies();
                diag.AppendLine(assemblies.Length + " assemblies loaded");
                foreach (var asm in assemblies)
                {
                    try
                    {
                        string asmName = asm.GetName().Name;
                        if (asmName.StartsWith("System") || asmName.StartsWith("mscorlib") ||
                            asmName.StartsWith("Microsoft") || asmName.StartsWith("Interop") ||
                            asmName.StartsWith("Newtonsoft") || asm.IsDynamic)
                            continue;

                        Type[] types;
                        try { types = asm.GetTypes(); }
                        catch (ReflectionTypeLoadException rtle) { types = rtle.Types; }
                        if (types == null) continue;

                        foreach (var type in types)
                        {
                            if (type == null) continue;
                            try
                            {
                                var flags = BindingFlags.Static | BindingFlags.Public | BindingFlags.NonPublic;
                                foreach (var fi in type.GetFields(flags))
                                {
                                    try
                                    {
                                        if (fi.FieldType.Name.Contains("AppCooperate") ||
                                            fi.FieldType.Name.Contains("IApplication") ||
                                            fi.FieldType.Name.Contains("IDocOCX"))
                                        {
                                            object val = fi.GetValue(null);
                                            if (val != null)
                                            {
                                                diag.AppendLine("  5F. " + type.Name + "." + fi.Name + " = " + val.GetType().FullName);
                                                IAppCooperate ac = val as IAppCooperate;
                                                if (ac != null)
                                                {
                                                    object doc = TryGetDocFromAppCooperate(ac, diag, "5F");
                                                    if (doc != null) return doc;
                                                }
                                                // Could be IDocOCX directly
                                                IDocOCX docOcx = val as IDocOCX;
                                                if (docOcx != null && docOcx.Document != null)
                                                    return docOcx.Document;
                                            }
                                        }
                                    }
                                    catch { }
                                }
                                foreach (var pi in type.GetProperties(flags))
                                {
                                    try
                                    {
                                        if ((pi.PropertyType.Name.Contains("AppCooperate") ||
                                             pi.PropertyType.Name.Contains("IApplication") ||
                                             pi.PropertyType.Name.Contains("IDocOCX")) &&
                                            pi.GetIndexParameters().Length == 0)
                                        {
                                            object val = pi.GetValue(null, null);
                                            if (val != null)
                                            {
                                                diag.AppendLine("  5P. " + type.Name + "." + pi.Name + " = " + val.GetType().FullName);
                                                IAppCooperate ac = val as IAppCooperate;
                                                if (ac != null)
                                                {
                                                    object doc = TryGetDocFromAppCooperate(ac, diag, "5P");
                                                    if (doc != null) return doc;
                                                }
                                                IDocOCX docOcx = val as IDocOCX;
                                                if (docOcx != null && docOcx.Document != null)
                                                    return docOcx.Document;
                                            }
                                        }
                                    }
                                    catch { }
                                }
                            }
                            catch { }
                        }
                    }
                    catch { }
                }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 6: Marshal.GetActiveObject (Running Object Table) ──
            string[] progIds = new[] {
                "Comos.Application", "COMOS.Application", "Comos.App",
                "Comos.Workset", "COMOS.Workset", "ComosApp.Application"
            };
            foreach (string progId in progIds)
            {
                try
                {
                    diag.Append("6. GetActiveObject('" + progId + "'): ");
                    object comObj = Marshal.GetActiveObject(progId);
                    if (comObj != null)
                    {
                        diag.AppendLine("OK, type=" + comObj.GetType().FullName);
                        IAppCooperate ac = comObj as IAppCooperate;
                        if (ac != null)
                        {
                            object doc = TryGetDocFromAppCooperate(ac, diag, "6");
                            if (doc != null) return doc;
                        }
                        try
                        {
                            dynamic dynObj = comObj;
                            object xdoc = dynObj.ActiveXDoc();
                            if (xdoc != null)
                            {
                                object doc = TryGetDocFromXDoc(xdoc, diag, "6-dyn");
                                if (doc != null) return doc;
                            }
                        }
                        catch { }
                    }
                    else { diag.AppendLine("null"); }
                }
                catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }
            }

            // ── Approach 7: XObj property (generic extension object) ──
            try
            {
                diag.Append("7. dynamic Workset.XObj: ");
                dynamic ws = Workset;
                object xObj = ws.XObj;
                if (xObj != null)
                {
                    diag.AppendLine("OK, type=" + xObj.GetType().FullName);
                    try
                    {
                        int sysType = (int)((dynamic)xObj).SystemType;
                        if (sysType == 29 || sysType == 30 || sysType == 31 || sysType == 32)
                            return xObj;
                    }
                    catch { }
                }
                else { diag.AppendLine("null"); }
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // ── Approach 8: Enumerate all COM interface names the Workset supports ──
            try
            {
                diag.Append("8. Workset interfaces: ");
                Type wsType = Workset.GetType();
                Type[] ifaces = wsType.GetInterfaces();
                var ifaceNames = new List<string>();
                foreach (var iface in ifaces) ifaceNames.Add(iface.Name);
                diag.AppendLine(string.Join(", ", ifaceNames.ToArray()));
            }
            catch (Exception ex) { diag.AppendLine("ERR: " + ex.Message); }

            // All approaches exhausted — write diagnostics to a file for easy access
            string diagText = diag.ToString();
            try
            {
                string diagPath = Path.Combine(
                    Path.GetDirectoryName(Assembly.GetExecutingAssembly().Location) ?? @"C:\temp",
                    "GetActiveDocument_diag.log");
                File.WriteAllText(diagPath, DateTime.Now.ToString("o") + "\n" + diagText);
            }
            catch { /* ignore file write errors */ }

            // Truncate diagnostics for the error message shown in chat (max 500 chars)
            string shortDiag = diagText.Length > 500 ? diagText.Substring(0, 500) + "..." : diagText;
            errorMessage = "Could not detect the active document in COMOS. " +
                "Please make sure a drawing is open. Full diagnostics written to GetActiveDocument_diag.log in SDK\\AI folder. " +
                "Summary: " + shortDiag.Replace("\r\n", " | ").Replace("\n", " | ");
            return null;
        }

        /// <summary>Helper: extract document from IAppCooperate via ActiveXDoc()</summary>
        private object TryGetDocFromAppCooperate(IAppCooperate appCoop, StringBuilder diag, string prefix)
        {
            try
            {
                IXDocCommand xdoc = appCoop.ActiveXDoc();
                if (xdoc != null)
                {
                    diag.AppendLine("  " + prefix + ". ActiveXDoc OK, type=" + ((object)xdoc).GetType().FullName);
                    return TryGetDocFromXDoc(xdoc, diag, prefix);
                }
                else
                {
                    diag.AppendLine("  " + prefix + ". ActiveXDoc=null (no drawing open?)");
                }
            }
            catch (Exception ex)
            {
                diag.AppendLine("  " + prefix + ". ActiveXDoc ERR: " + ex.Message);
            }
            return null;
        }

        /// <summary>Helper: extract IComosDDocument from an XDoc object (cast to IDocOCX or dynamic)</summary>
        private object TryGetDocFromXDoc(object xdoc, StringBuilder diag, string prefix)
        {
            // Try cast to IDocOCX — the canonical way to get the Document
            try
            {
                IDocOCX docOcx = xdoc as IDocOCX;
                if (docOcx != null)
                {
                    IComosDDocument doc = docOcx.Document;
                    if (doc != null)
                    {
                        string docName = "?";
                        try { docName = ((dynamic)doc).Name; } catch { }
                        diag.AppendLine("  " + prefix + ". IDocOCX.Document OK: " + docName);
                        return doc;
                    }
                    else { diag.AppendLine("  " + prefix + ". IDocOCX.Document=null"); }
                }
                else { diag.AppendLine("  " + prefix + ". xdoc as IDocOCX=null, xdoc type=" + xdoc.GetType().FullName); }
            }
            catch (Exception ex) { diag.AppendLine("  " + prefix + ". IDocOCX ERR: " + ex.Message); }

            // Try dynamic .Document
            try
            {
                dynamic dynXdoc = xdoc;
                object doc = dynXdoc.Document;
                if (doc != null)
                {
                    string docName = "?";
                    try { docName = ((dynamic)doc).Name; } catch { }
                    diag.AppendLine("  " + prefix + ". dynamic.Document OK: " + docName);
                    return doc;
                }
                else { diag.AppendLine("  " + prefix + ". dynamic.Document=null"); }
            }
            catch (Exception ex) { diag.AppendLine("  " + prefix + ". dynamic.Document ERR: " + ex.Message); }

            // Try dynamic .CDocument
            try
            {
                dynamic dynXdoc = xdoc;
                object doc = dynXdoc.CDocument;
                if (doc != null)
                {
                    diag.AppendLine("  " + prefix + ". dynamic.CDocument OK");
                    return doc;
                }
            }
            catch (Exception ex) { diag.AppendLine("  " + prefix + ". dynamic.CDocument ERR: " + ex.Message); }

            return null;
        }

        /// <summary>
        /// Resolve a document: try LoadObjectByType by SystemUID first.
        /// If that fails (e.g. user gave a Name like "FA.020" instead of UID),
        /// fall back to COMOS SearchManager to find by Name.
        /// </summary>
        private object ResolveDocument(int documentType, string uidOrName)
        {
            string normalized = NormalizeDocumentIdentifier(uidOrName);
            if (string.IsNullOrWhiteSpace(normalized)) return null;

            List<string> candidates = BuildDocumentCandidates(normalized);
            List<int> docTypes = BuildDocumentTypeCandidates(documentType);

            // 1. Try direct UID loads first (all candidate document types)
            for (int t = 0; t < docTypes.Count; t++)
            {
                for (int i = 0; i < candidates.Count; i++)
                {
                    try
                    {
                        object doc = Workset.LoadObjectByType(docTypes[t], candidates[i]);
                        if (doc != null) return doc;
                    }
                    catch { }
                }
            }

            // 2. Try dynamic LoadObject(systemType, uidOrName)
            try
            {
                dynamic ws = Workset;
                for (int t = 0; t < docTypes.Count; t++)
                {
                    for (int i = 0; i < candidates.Count; i++)
                    {
                        try
                        {
                            object doc = ws.LoadObject(docTypes[t].ToString(), candidates[i]);
                            if (doc != null) return doc;
                        }
                        catch { }
                    }
                }
            }
            catch { }

            // 3. SearchManager by Name/Label across common document system types
            for (int t = 0; t < docTypes.Count; t++)
            {
                for (int i = 0; i < candidates.Count; i++)
                {
                    object byName = SearchDocumentByAttribute(docTypes[t], "Name", candidates[i]);
                    if (byName != null) return byName;

                    object byLabel = SearchDocumentByAttribute(docTypes[t], "Label", candidates[i]);
                    if (byLabel != null) return byLabel;
                }
            }

            // 4. Walk project tree by visible name
            try
            {
                var project = Workset.GetCurrentProject();
                if (project != null)
                {
                    object projectCollectionHit = FindDocumentByProjectCollections(project, candidates, docTypes);
                    if (projectCollectionHit != null) return projectCollectionHit;

                    for (int t = 0; t < docTypes.Count; t++)
                    {
                        for (int i = 0; i < candidates.Count; i++)
                        {
                            object found = FindDocumentByNameInProject(project, candidates[i], docTypes[t]);
                            if (found != null) return found;
                        }
                    }
                }
            }
            catch { }

            // 5. Try full file name resolver for each candidate
            for (int i = 0; i < candidates.Count; i++)
            {
                try
                {
                    IComosDDocument docByFile = Workset.GetDocumentByFullFileName(candidates[i]);
                    if (docByFile != null) return docByFile;
                }
                catch { }

                // Additional project path-based resolver
                try
                {
                    var project = Workset.GetCurrentProject();
                    if (project != null)
                    {
                        object byPath = project.GetObjectByPathFullName(candidates[i]);
                        // Only return if it's actually a document — GetObjectByPathFullName
                        // can return units, devices, or other non-document objects.
                        if (byPath != null && byPath is IComosDDocument) return byPath;
                    }
                }
                catch { }
            }

            return null;
        }

        private object FindDocumentByProjectCollections(IComosDProject project, List<string> candidates, List<int> docTypes)
        {
            if (project == null || candidates == null || candidates.Count == 0) return null;

            // 1) Type-filtered collections first
            if (docTypes != null)
            {
                for (int t = 0; t < docTypes.Count; t++)
                {
                    try
                    {
                        dynamic byType = project.AllDocumentsWithDocumentType(docTypes[t]);
                        object hit = FindDocumentInCollection(byType, candidates, docTypes[t]);
                        if (hit != null) return hit;
                    }
                    catch { }
                }
            }

            // 2) Fallback: all documents
            try
            {
                dynamic allDocs = project.AllDocuments();
                object hit = FindDocumentInCollection(allDocs, candidates, null);
                if (hit != null) return hit;
            }
            catch { }

            return null;
        }

        private object FindDocumentInCollection(dynamic docs, List<string> candidates, int? expectedType)
        {
            if (docs == null || candidates == null || candidates.Count == 0) return null;

            try
            {
                int count = docs.Count;
                for (int i = 1; i <= count; i++)
                {
                    object docObj = null;
                    try { docObj = docs.Item(i); }
                    catch { continue; }
                    if (docObj == null) continue;

                    if (expectedType.HasValue)
                    {
                        try
                        {
                            int st = (int)((dynamic)docObj).SystemType;
                            if (st != expectedType.Value) continue;
                        }
                        catch { }
                    }

                    if (DocumentMatchesCandidates(docObj, candidates))
                        return docObj;
                }
            }
            catch { }

            return null;
        }

        private bool DocumentMatchesCandidates(object docObj, List<string> candidates)
        {
            if (docObj == null || candidates == null || candidates.Count == 0) return false;

            List<string> values = new List<string>();
            try { AddCandidate(values, (string)((dynamic)docObj).Name); } catch { }
            try { AddCandidate(values, (string)((dynamic)docObj).Label); } catch { }
            try { AddCandidate(values, (string)((dynamic)docObj).FullName()); } catch { }
            try { AddCandidate(values, (string)((dynamic)docObj).FullLabel()); } catch { }
            try { AddCandidate(values, (string)((dynamic)docObj).SystemFullName()); } catch { }

            for (int i = 0; i < candidates.Count; i++)
            {
                string c = NormalizeDocumentIdentifier(candidates[i]);
                for (int j = 0; j < values.Count; j++)
                {
                    if (values[j].Equals(c, StringComparison.OrdinalIgnoreCase))
                        return true;
                }
            }

            return false;
        }

        private static List<int> BuildDocumentTypeCandidates(int preferredType)
        {
            List<int> types = new List<int>();
            if (preferredType > 0) types.Add(preferredType);
            if (!types.Contains(29)) types.Add(29);
            if (!types.Contains(30)) types.Add(30);
            if (!types.Contains(31)) types.Add(31);
            if (!types.Contains(32)) types.Add(32);
            return types;
        }

        private static List<string> BuildDocumentCandidates(string raw)
        {
            List<string> values = new List<string>();
            AddCandidate(values, raw);

            if (raw.StartsWith("=", StringComparison.Ordinal))
                AddCandidate(values, raw.Substring(1));

            int lastDot = raw.LastIndexOf('.');
            if (lastDot > 0)
            {
                int prevDot = raw.LastIndexOf('.', lastDot - 1);
                if (prevDot >= 0)
                    AddCandidate(values, raw.Substring(prevDot + 1));
            }

            return values;
        }

        private static void AddCandidate(List<string> values, string value)
        {
            string normalized = NormalizeDocumentIdentifier(value);
            if (string.IsNullOrWhiteSpace(normalized)) return;
            if (!values.Contains(normalized)) values.Add(normalized);
        }

        private static string NormalizeDocumentIdentifier(string value)
        {
            if (string.IsNullOrWhiteSpace(value)) return string.Empty;

            string normalized = value.Trim();
            normalized = normalized.Trim('`', '\'', '"');

            if (normalized.StartsWith("**", StringComparison.Ordinal) &&
                normalized.EndsWith("**", StringComparison.Ordinal) &&
                normalized.Length > 4)
            {
                normalized = normalized.Substring(2, normalized.Length - 4).Trim();
            }

            return normalized;
        }

        private object SearchDocumentByAttribute(int systemType, string attribute, string value)
        {
            try
            {
                IComosDSearchManager searchMgr = Workset.GetSearchManager();
                if (searchMgr == null) return null;

                searchMgr.SystemType = systemType;
                searchMgr.AppendSearchCondition(
                    "",
                    "Name",
                    attribute,
                    "=",
                    value
                );

                IComosDCollection results = searchMgr.Start();
                if (results != null && results.Count() > 0)
                    return results.Item(1);
            }
            catch { }

            return null;
        }

        /// <summary>
        /// Walk the COMOS project tree (units and their documents) to find a
        /// document whose Name matches the given name.  Max depth = 5.
        /// </summary>
        private object FindDocumentByNameInProject(IComosDProject project, string name, int documentType)
        {
            try
            {
                dynamic dynProj = project;
                return WalkUnitsForDocument(dynProj, name, documentType, 0);
            }
            catch { return null; }
        }

        private object WalkUnitsForDocument(dynamic parent, string name, int documentType, int depth)
        {
            if (depth > 5) return null;

            string target = NormalizeDocumentIdentifier(name);

            // Check documents directly attached to this unit/object
            try
            {
                dynamic docs = parent.Documents;
                if (docs != null)
                {
                    int docCount = docs.Count;
                    for (int i = 1; i <= docCount; i++)
                    {
                        try
                        {
                            dynamic doc = docs.Item(i);
                            if (doc == null) continue;
                            string docName = null;
                            string docLabel = null;
                            try { docName = NormalizeDocumentIdentifier((string)doc.Name); } catch { }
                            try { docLabel = NormalizeDocumentIdentifier((string)doc.Label); } catch { }

                            if ((!string.IsNullOrEmpty(docName) && docName.Equals(target, StringComparison.OrdinalIgnoreCase)) ||
                                (!string.IsNullOrEmpty(docLabel) && docLabel.Equals(target, StringComparison.OrdinalIgnoreCase)))
                            {
                                return doc;
                            }
                        }
                        catch { continue; }
                    }
                }
            }
            catch { /* Documents collection not available */ }

            // Check DevObjects (devices may own documents)
            try
            {
                dynamic devObjs = parent.DevObjects;
                if (devObjs != null)
                {
                    int devCount = devObjs.Count;
                    for (int i = 1; i <= devCount; i++)
                    {
                        try
                        {
                            dynamic child = devObjs.Item(i);
                            if (child == null) continue;
                            string childName = (string)child.Name;
                            if (!string.IsNullOrEmpty(childName) &&
                                childName.Equals(name, StringComparison.OrdinalIgnoreCase))
                            {
                                // Check if this child IS a document (type matches)
                                try
                                {
                                    int childType = (int)child.SystemType;
                                    if (childType == documentType) return child;
                                }
                                catch { /* check Name match is enough, return it */ return child; }
                            }
                            // Recurse into child
                            object found = WalkUnitsForDocument(child, name, documentType, depth + 1);
                            if (found != null) return found;
                        }
                        catch { continue; }
                    }
                }
            }
            catch { /* DevObjects not available */ }

            return null;
        }

        /// <summary>
        /// Scan a COMOS document's owner hierarchy for a device matching
        /// the given tag. This finds objects regardless of how/when they
        /// were created — batch import, interactive draw, or pre-existing.
        /// </summary>
        private static IComosDDevice FindDeviceOnDocument(object docObj, string tag, IComosDProject project)
        {
            if (docObj == null || string.IsNullOrWhiteSpace(tag)) return null;
            try
            {
                // The document's Owner is the parent device in the hierarchy.
                // Devices that BELONG to this document's owner are in its DevObjects.
                dynamic dynDoc = docObj;
                dynamic owner = dynDoc.Owner;
                if (owner == null) return null;

                // Recursively search DevObjects under the owner
                IComosDDevice found = ScanDevObjects(owner, tag, 0);
                if (found != null) return found;
            }
            catch { /* Owner/DevObjects not available */ }

            // Fallback 1: project-wide flat scan via AllDevices() + BackPointerDocObjs check.
            // NOTE: IComosDProject does NOT have a .DevObjects property — ScanDevObjects(project,…)
            //       would silently fail. The correct API is project.AllDevices() (a method).
            string docUID = TryGetStringProperty(docObj, "SystemUID");
            try
            {
                if (project != null)
                {
                    dynamic allDevs = ((dynamic)project).AllDevices();
                    if (allDevs != null)
                    {
                        int devCount = allDevs.Count;
                        for (int i = 1; i <= devCount; i++)
                        {
                            try
                            {
                                dynamic dev = allDevs.Item(i);
                                if (dev == null) continue;
                                if (!DeviceMatchesTag(dev, tag)) continue;
                                IComosDDevice typed = dev as IComosDDevice;
                                if (typed == null) continue;

                                // Verify the device is placed on this specific document.
                                // Check BackPointerDocObjs: each entry is a placed representation;
                                // its Owner should be the document that contains it.
                                bool placedOnDoc = false;
                                if (!string.IsNullOrWhiteSpace(docUID))
                                {
                                    try
                                    {
                                        dynamic bpDocs = dev.BackPointerDocObjs;
                                        if (bpDocs != null)
                                        {
                                            int bpCount = bpDocs.Count;
                                            for (int j = 1; j <= bpCount && !placedOnDoc; j++)
                                            {
                                                try
                                                {
                                                    dynamic bpItem = bpDocs.Item(j);
                                                    if (bpItem == null) continue;

                                                    // bpItem itself might be the document
                                                    string bpUID = TryGetStringProperty(bpItem, "SystemUID");
                                                    if (docUID.Equals(bpUID, StringComparison.OrdinalIgnoreCase))
                                                    { placedOnDoc = true; break; }

                                                    // or bpItem.Owner is the containing document
                                                    try
                                                    {
                                                        dynamic bpOwner = bpItem.Owner;
                                                        if (bpOwner != null)
                                                        {
                                                            string owUID = TryGetStringProperty(bpOwner, "SystemUID");
                                                            if (docUID.Equals(owUID, StringComparison.OrdinalIgnoreCase))
                                                            { placedOnDoc = true; break; }
                                                        }
                                                    }
                                                    catch { }
                                                }
                                                catch { continue; }
                                            }
                                        }
                                    }
                                    catch { }
                                }

                                // Also accept if the device is an ancestor/descendant of doc owner
                                if (!placedOnDoc) placedOnDoc = DeviceBelongsToDocument(typed, docObj);

                                if (placedOnDoc) return typed;
                            }
                            catch { continue; }
                        }
                    }
                }
            }
            catch { }

            // Fallback 2: scan owners from all project documents (finds devices under any doc owner)
            try
            {
                if (project != null)
                {
                    dynamic allDocs = ((dynamic)project).AllDocuments();
                    if (allDocs != null)
                    {
                        int count = allDocs.Count;
                        for (int i = 1; i <= count; i++)
                        {
                            try
                            {
                                dynamic d = allDocs.Item(i);
                                if (d == null) continue;
                                dynamic owner = d.Owner;
                                if (owner == null) continue;

                                IComosDDevice found = ScanDevObjects(owner, tag, 0);
                                if (found != null) return found;
                            }
                            catch { continue; }
                        }
                    }
                }
            }
            catch { }

            // NOTE: GetHierarchyObjectByName is intentionally NOT used here.
            // That method navigates the functional/unit hierarchy only — it has no knowledge
            // of the document tree (P&IDs, diagrams). Using it would return a device without
            // verifying whether it is actually placed on the target document.

            return null;
        }

        private static IComosDDevice FindDeviceOnDocumentStrict(object docObj, string tag, IComosDProject project)
        {
            if (docObj == null || string.IsNullOrWhiteSpace(tag)) return null;

            try
            {
                dynamic dynDoc = docObj;
                dynamic owner = dynDoc.Owner;
                if (owner != null)
                {
                    IComosDDevice found = ScanDevObjects(owner, tag, 0);
                    if (found != null) return found;
                }
            }
            catch { }

            try
            {
                IComosDDevice foundOnDoc = ScanDevObjects(docObj, tag, 0);
                if (foundOnDoc != null) return foundOnDoc;
            }
            catch { }

            // Safe fallback: broader search via AllDevices + BackPointerDocObjs
            // (FindDeviceOnDocument already verifies placement, so accept its result directly)
            try
            {
                IComosDDevice candidate = FindDeviceOnDocument(docObj, tag, project);
                if (candidate != null) return candidate;
            }
            catch { }

            return null;
        }

        private static bool DeviceBelongsToDocument(IComosDDevice device, object docObj)
        {
            if (device == null || docObj == null) return false;

            string docUid = TryGetStringProperty(docObj, "SystemUID");
            object docOwner = null;
            string ownerUid = "";
            try
            {
                dynamic d = docObj;
                docOwner = d.Owner;
                ownerUid = TryGetStringProperty(docOwner, "SystemUID");
            }
            catch { }

            try
            {
                object current = device;
                int guard = 0;
                while (current != null && guard++ < 64)
                {
                    string currentUid = TryGetStringProperty(current, "SystemUID");
                    if (!string.IsNullOrWhiteSpace(docUid) && !string.IsNullOrWhiteSpace(currentUid) &&
                        currentUid.Equals(docUid, StringComparison.OrdinalIgnoreCase))
                    {
                        return true;
                    }

                    if (!string.IsNullOrWhiteSpace(ownerUid) && !string.IsNullOrWhiteSpace(currentUid) &&
                        currentUid.Equals(ownerUid, StringComparison.OrdinalIgnoreCase))
                    {
                        return true;
                    }

                    object next = null;
                    try
                    {
                        dynamic dyn = current;
                        next = dyn.Owner;
                    }
                    catch { }
                    current = next;
                }
            }
            catch { }

            return false;
        }

        private static bool IsConnectedToExpectedSource(object connectedWith, IComosDConnector expectedSourceConnector, IComosDDevice expectedSourceDevice)
        {
            if (connectedWith == null) return false;

            // Check 1: COM reference equality (most reliable — same object in memory)
            if (expectedSourceConnector != null)
            {
                try
                {
                    if (object.ReferenceEquals(connectedWith, expectedSourceConnector))
                        return true;
                }
                catch { }
            }

            // Check 2: SystemUID equality on the connector objects (cross-apartment safe)
            if (expectedSourceConnector != null)
            {
                try
                {
                    string cwUID  = TryGetStringProperty(connectedWith, "SystemUID");
                    string srcUID = TryGetStringProperty(expectedSourceConnector, "SystemUID");
                    if (!string.IsNullOrWhiteSpace(cwUID) && cwUID.Equals(srcUID, StringComparison.OrdinalIgnoreCase))
                        return true;
                }
                catch { }
            }

            // Check 3: Same connector name on same device (name + verified owner UID)
            if (expectedSourceConnector != null && expectedSourceDevice != null)
            {
                try
                {
                    dynamic cw     = connectedWith;
                    dynamic srcCon = expectedSourceConnector;
                    string cwName  = NormalizeTagForLookup((string)cw.Name);
                    string srcName = NormalizeTagForLookup((string)srcCon.Name);
                    if (!string.IsNullOrWhiteSpace(cwName) &&
                        cwName.Equals(srcName, StringComparison.OrdinalIgnoreCase) &&
                        IsSameOwnerBySystemUID(cw, expectedSourceDevice))
                    {
                        return true;
                    }
                }
                catch { }
            }

            // NOTE: The loose IsSameOwnerBySystemUID-only fallback has been removed.
            // It returned true whenever connectedWith's owner matched sourceDev, which
            // caused false positives when ConnectedWith() returned a pre-existing connector
            // owned by the source device but not the one we just connected.
            return false;
        }

        private static bool IsSameOwnerBySystemUID(object connectorObj, object expectedOwner)
        {
            if (connectorObj == null || expectedOwner == null) return false;

            string expectedUID = TryGetStringProperty(expectedOwner, "SystemUID");
            if (string.IsNullOrWhiteSpace(expectedUID)) return false;

            try
            {
                dynamic d = connectorObj;
                object owner = null;
                try { owner = d.Owner; } catch { }
                if (owner == null) return false;

                string ownerUID = TryGetStringProperty(owner, "SystemUID");
                return !string.IsNullOrWhiteSpace(ownerUID) && ownerUID.Equals(expectedUID, StringComparison.OrdinalIgnoreCase);
            }
            catch
            {
                return false;
            }
        }

        private static string TryGetStringProperty(object obj, string propertyName)
        {
            if (obj == null || string.IsNullOrWhiteSpace(propertyName)) return "";

            try
            {
                Type t = obj.GetType();
                PropertyInfo p = t.GetProperty(propertyName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
                if (p != null)
                {
                    object value = p.GetValue(obj, null);
                    return value == null ? "" : Convert.ToString(value);
                }
            }
            catch { }

            return "";
        }

        private static string DescribeDeviceIdentity(IComosDDevice device)
        {
            if (device == null) return "(null)";

            string name = TryGetStringProperty(device, "Name");
            string label = TryGetStringProperty(device, "Label");
            string uid = TryGetStringProperty(device, "SystemUID");

            object owner = null;
            string ownerUID = "";
            try
            {
                dynamic d = device;
                owner = d.Owner;
                ownerUID = TryGetStringProperty(owner, "SystemUID");
            }
            catch { }

            return string.Format("Name={0}; Label={1}; UID={2}; OwnerUID={3}",
                string.IsNullOrWhiteSpace(name) ? "?" : name,
                string.IsNullOrWhiteSpace(label) ? "?" : label,
                string.IsNullOrWhiteSpace(uid) ? "?" : uid,
                string.IsNullOrWhiteSpace(ownerUID) ? "?" : ownerUID);
        }

        /// <summary>
        /// Recursively scan a device's DevObjects tree for a child
        /// whose Name matches the given tag. Max depth = 3 to avoid
        /// traversing the entire project.
        /// </summary>
        private static IComosDDevice ScanDevObjects(dynamic parent, string tag, int depth)
        {
            if (depth > 64) return null;
            try
            {
                dynamic devObjs = parent.DevObjects;
                if (devObjs == null) return null;
                int count = devObjs.Count;
                for (int i = 1; i <= count; i++)
                {
                    try
                    {
                        dynamic item = devObjs.Item(i);
                        if (item == null) continue;
                        if (DeviceMatchesTag(item, tag))
                        {
                            IComosDDevice matched = null;
                            try { matched = item as IComosDDevice; }
                            catch { }

                            // Some COM objects can match by name/label but are not directly
                            // castable to IComosDDevice in this runtime context.
                            // Do not abort the search in this case; continue traversal.
                            if (matched != null)
                                return matched;
                        }
                        // Recurse into children
                        IComosDDevice child = ScanDevObjects(item, tag, depth + 1);
                        if (child != null) return child;
                    }
                    catch { continue; }
                }
            }
            catch { /* DevObjects not available on this object */ }
            return null;
        }

        private static bool DeviceMatchesTag(dynamic item, string tag)
        {
            try
            {
                foreach (string candidate in BuildTagCandidates(tag))
                {
                    string normalizedCandidate = NormalizeTagForLookup(candidate);
                    string withoutEqCandidate = normalizedCandidate.StartsWith("=", StringComparison.Ordinal)
                        ? normalizedCandidate.Substring(1)
                        : normalizedCandidate;

                    try
                    {
                        string name = NormalizeTagForLookup((string)item.Name);
                        string nameWithoutEq = name.StartsWith("=", StringComparison.Ordinal) ? name.Substring(1) : name;
                        if (name.Equals(normalizedCandidate, StringComparison.OrdinalIgnoreCase) ||
                            nameWithoutEq.Equals(withoutEqCandidate, StringComparison.OrdinalIgnoreCase))
                            return true;
                    }
                    catch { }

                    try
                    {
                        string label = NormalizeTagForLookup((string)item.Label);
                        string labelWithoutEq = label.StartsWith("=", StringComparison.Ordinal) ? label.Substring(1) : label;
                        if (label.Equals(normalizedCandidate, StringComparison.OrdinalIgnoreCase) ||
                            labelWithoutEq.Equals(withoutEqCandidate, StringComparison.OrdinalIgnoreCase))
                            return true;
                    }
                    catch { }

                    try
                    {
                        string alias = NormalizeTagForLookup((string)item.AliasFullLabel());
                        if (!string.IsNullOrWhiteSpace(alias) && alias.Equals(normalizedCandidate, StringComparison.OrdinalIgnoreCase))
                            return true;
                    }
                    catch { }
                }
            }
            catch { }

            return false;
        }

        private static List<string> BuildTagCandidates(string tag)
        {
            var values = new List<string>();
            string normalized = NormalizeTagForLookup(tag);
            if (string.IsNullOrWhiteSpace(normalized)) return values;

            if (!values.Contains(normalized)) values.Add(normalized);

            string withoutMarkers = normalized;
            while (withoutMarkers.StartsWith("=", StringComparison.Ordinal) || withoutMarkers.StartsWith("~", StringComparison.Ordinal))
            {
                withoutMarkers = withoutMarkers.Substring(1);
            }
            if (!string.IsNullOrWhiteSpace(withoutMarkers) && !values.Contains(withoutMarkers)) values.Add(withoutMarkers);

            if (normalized.StartsWith("=", StringComparison.Ordinal))
            {
                string withoutEq = normalized.Substring(1);
                if (!string.IsNullOrWhiteSpace(withoutEq) && !values.Contains(withoutEq)) values.Add(withoutEq);
            }
            else
            {
                string withEq = "=" + normalized;
                if (!values.Contains(withEq)) values.Add(withEq);
            }

            string withTilde = "~" + withoutMarkers;
            if (!string.IsNullOrWhiteSpace(withoutMarkers) && !values.Contains(withTilde)) values.Add(withTilde);

            string withEqTilde = "=~" + withoutMarkers;
            if (!string.IsNullOrWhiteSpace(withoutMarkers) && !values.Contains(withEqTilde)) values.Add(withEqTilde);

            string withTildeEq = "~=" + withoutMarkers;
            if (!string.IsNullOrWhiteSpace(withoutMarkers) && !values.Contains(withTildeEq)) values.Add(withTildeEq);

            return values;
        }

        private static string NormalizeTagForLookup(string value)
        {
            if (string.IsNullOrWhiteSpace(value)) return string.Empty;
            string normalized = value.Trim();
            normalized = normalized.Trim('`', '\'', '"');
            return normalized;
        }

        /// <summary>Obtém conector por nome.</summary>
        private static IComosDConnector GetConnector(IComosDDevice device, string pinName)
        {
            try
            {
                var connectors = device.Connectors();
                if (connectors == null) return null;
                return connectors.Item(pinName) as IComosDConnector;
            }
            catch { return null; }
        }

        /// <summary>
        /// Get connector by name; if it's already connected, use GU_GetLikeConnector
        /// to create a parallel connector (matching the VBS pattern).
        /// </summary>
        private static IComosDConnector GetConnectorOrLike(IComosDDevice device, string pinName, dynamic globalUtilities)
        {
            try
            {
                var connectors = device.Connectors();
                if (connectors == null) return null;
                var con = connectors.Item(pinName) as IComosDConnector;
                if (con == null) return null;

                // If connector is free (not connected), return it directly
                try
                {
                    object cw = con.ConnectedWith();
                    if (cw == null)
                        return con;
                }
                catch
                {
                    // ConnectedWith may throw if not connected — treat as free
                    return con;
                }

                // Connector is occupied — try to get a "like" connector
                if (globalUtilities != null)
                {
                    try
                    {
                        IComosDConnector likeCon = globalUtilities.GU_GetLikeConnector(con);
                        if (likeCon != null) return likeCon;
                    }
                    catch { /* GU_GetLikeConnector failed, fall through to return original */ }
                }

                // Fallback: return the original connector (Connect may still work or fail gracefully)
                return con;
            }
            catch { return null; }
        }

        private static IComosDConnector GetConnectorOrCreateLike(IComosDDevice device, string pinName, dynamic globalUtilities, out bool created)
        {
            created = false;

            IComosDConnector con = GetConnectorOrLike(device, pinName, globalUtilities);
            if (con != null) return con;

            if (globalUtilities == null || device == null) return null;

            IComosDConnector template = FindTemplateConnector(device, pinName);
            if (template == null)
            {
                IComosDConnector hardCreated = EnsureConnectorExists(device, pinName);
                if (hardCreated != null)
                {
                    created = true;
                    return hardCreated;
                }
                return null;
            }

            try
            {
                IComosDConnector newCon = globalUtilities.GU_GetLikeConnector(template);
                if (newCon == null) return null;

                created = true;

                IComosDConnector named = GetConnector(device, pinName);
                if (named != null) return named;

                return newCon;
            }
            catch
            {
                IComosDConnector hardCreated = EnsureConnectorExists(device, pinName);
                if (hardCreated != null)
                {
                    created = true;
                    return hardCreated;
                }
                return null;
            }
        }

        private static IComosDConnector EnsureConnectorExists(IComosDDevice device, string pinName)
        {
            if (device == null || string.IsNullOrWhiteSpace(pinName)) return null;

            // 1) After default element creation, many symbols receive EB01/EB02 automatically
            try
            {
                device.CreateDefaultElements();
                IComosDConnector afterDefault = GetConnector(device, pinName);
                if (afterDefault != null) return afterDefault;
            }
            catch { }

            // 2) Explicitly create connector in OwnConnectors with the requested pin name
            try
            {
                dynamic own = device.OwnConnectors();
                if (own != null)
                {
                    try
                    {
                        object createdNamed = own.CreateNewWithName(pinName);
                        IComosDConnector conNamed = createdNamed as IComosDConnector;
                        if (conNamed != null) return conNamed;
                    }
                    catch { }

                    try
                    {
                        object createdGeneric = own.CreateNew();
                        if (createdGeneric != null)
                        {
                            try { ((dynamic)createdGeneric).Name = pinName; } catch { }
                            IComosDConnector conGeneric = createdGeneric as IComosDConnector;
                            if (conGeneric != null) return conGeneric;
                        }
                    }
                    catch { }
                }
            }
            catch { }

            // 3) Final re-read from device connector collection
            try
            {
                return GetConnector(device, pinName);
            }
            catch { }

            return null;
        }

        private static IComosDConnector FindTemplateConnector(IComosDDevice device, string desiredPinName)
        {
            if (device == null) return null;

            try
            {
                var connectors = device.Connectors();
                if (connectors == null) return null;

                string prefix = GetPinPrefix(desiredPinName);
                IComosDConnector first = null;
                int count = connectors.Count();

                for (int i = 1; i <= count; i++)
                {
                    IComosDConnector candidate = null;
                    try { candidate = connectors.Item(i) as IComosDConnector; }
                    catch { continue; }

                    if (candidate == null) continue;
                    if (first == null) first = candidate;

                    try
                    {
                        string name = (string)((dynamic)candidate).Name;
                        if (!string.IsNullOrWhiteSpace(name) &&
                            !string.IsNullOrWhiteSpace(prefix) &&
                            name.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                        {
                            return candidate;
                        }
                    }
                    catch { }
                }

                return first;
            }
            catch
            {
                return null;
            }
        }

        private static string GetPinPrefix(string pinName)
        {
            if (string.IsNullOrWhiteSpace(pinName)) return string.Empty;

            string p = pinName.Trim();
            int idx = 0;
            while (idx < p.Length && char.IsLetter(p[idx])) idx++;

            if (idx <= 0) return p;
            return p.Substring(0, idx);
        }

        /// <summary>Gets a string from the cell array, safe against out-of-bounds</summary>
        private static string CellStr(string[] cells, int colIdx)
        {
            if (cells == null || colIdx < 0 || colIdx >= cells.Length) return "";
            return (cells[colIdx] ?? "").Trim();
        }

        /// <summary>Gets a double from the cell array, with default fallback</summary>
        private static double CellDbl(string[] cells, int colIdx, double defaultVal)
        {
            string s = CellStr(cells, colIdx);
            if (string.IsNullOrEmpty(s)) return defaultVal;
            double d;
            if (double.TryParse(s, NumberStyles.Any, CultureInfo.InvariantCulture, out d))
                return d;
            return defaultVal;
        }


        // ══════════════════════════════════════════════════════════════════
        // TOOL 4: extract_and_create_tags — Hierarchy-only creation
        //   Creates objects in the COMOS hierarchy from extracted TAGs
        //   WITHOUT drawing on a diagram or creating connections.
        //   Used by option 3 ("Tags Only") — regex/LLM extraction flow.
        // ══════════════════════════════════════════════════════════════════

        [AiFunction(
            "extract_and_create_tags",
            "Creates equipment/instrument objects in the COMOS hierarchy " +
            "from extracted TAGs (tag + description + SystemFullName). " +
            "This is a hierarchy-only creation — NO drawing on diagrams, " +
            "NO connections. Used for bulk tag import from PDF tag extraction. " +
            "The payload is a TSV (tab-separated) base64-encoded string " +
            "with format: tag\\tdescricao\\tSystemFullName per line.")]
        public object ExtractAndCreateTags(
            [DescribeParameter(
                "Base64-encoded TSV payload with extracted tags. " +
                "Each line: tag\\tdescricao\\tSystemFullName. " +
                "Prefix with __TAGS_TSV_B64__: for identification.",
                ExampleValue = "__TAGS_TSV_B64__:dGFnMQlkZXNjMQlAMzB8TTQx...")]
            string tagsPayload,

            [DescribeParameter(
                "SystemUID of a target COMOS document (or 'ACTIVE' for currently selected). " +
                "Objects will be created under this document's owner/parent.",
                ExampleValue = "ACTIVE")]
            string documentUID,

            [DescribeParameter(
                "Document type number in COMOS (usually 29)",
                ExampleValue = "29")]
            int documentType)
        {
            if (Workset == null)
                return new { success = false, error = "Workset not available. COMOS must be running with an open project." };

            if (string.IsNullOrWhiteSpace(tagsPayload))
                return new { success = false, error = "tagsPayload is required." };

            string normalizedPayload = (tagsPayload ?? "").Trim();

            // ── Extract base64 TSV ──
            string tsvB64;
            if (!TryExtractPayload(normalizedPayload,
                    new[] { "__TAGS_TSV_B64__:", "TAGS_TSV_B64:", "__CACHE_TSV_B64__:", "CACHE_TSV_B64:", "CACHE:" },
                    out tsvB64))
            {
                // Try treating the entire payload as base64
                tsvB64 = normalizedPayload;
            }

            List<string[]> rows;
            try
            {
                rows = ReadRowsFromTagsPayload(tsvB64);
            }
            catch (Exception ex)
            {
                return new { success = false, error = "Failed to parse tags payload: " + ex.Message };
            }

            if (rows.Count == 0)
                return new { success = false, error = "No tags found in payload." };

            // ── Resolve document ──
            string resolvedDocUID = (documentUID ?? "").Trim();
            bool isActiveMode = string.IsNullOrWhiteSpace(resolvedDocUID) || resolvedDocUID.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase);
            object activeDocObj = null;

            if (isActiveMode)
            {
                string activeError;
                activeDocObj = GetActiveDocument(out activeError);
                if (activeDocObj == null)
                    return new { success = false, error = activeError ?? "No document is currently open in COMOS. Please open the target drawing (P&ID or Diagram) first." };
                try { resolvedDocUID = ((dynamic)activeDocObj).SystemUID; } catch { resolvedDocUID = "ACTIVE"; }
            }

            // ── Load project and document ──
            var project = Workset.GetCurrentProject();
            if (project == null)
                return new { success = false, error = "No project is currently open in COMOS." };

            object docObj = activeDocObj ?? ResolveDocument(documentType, resolvedDocUID);
            if (docObj == null)
                return new { success = false, error = string.Format("Document not found (Type={0}, UID/Name={1}). Please open the target drawing in COMOS.", documentType, resolvedDocUID) };

            _QsGlobalObj qsGlobal;
            try
            {
                qsGlobal = (_QsGlobalObj)(new QsGlobalObjClass());
            }
            catch (Exception ex)
            {
                return new { success = false, error = "Failed to instantiate QsGlobalObj: " + ex.Message };
            }

            // ── Create objects in hierarchy (PASSO 1 only) ──
            var baseBySFN = new Dictionary<string, IComosDCDevice>();
            int createdCount = 0;
            int skipCount = 0;
            var errors = new List<string>();
            var createdTags = new List<string>();

            for (int i = 0; i < rows.Count; i++)
            {
                var cols = rows[i];
                int rowNum = i + 1;
                try
                {
                    // TSV format: tag \t descricao \t SystemFullName
                    string tag = (cols.Length > 0) ? cols[0].Trim() : "";
                    string desc = (cols.Length > 1) ? cols[1].Trim() : "";
                    string sfn = (cols.Length > 2) ? cols[2].Trim() : "";

                    if (string.IsNullOrWhiteSpace(tag))
                    {
                        skipCount++;
                        continue;
                    }

                    if (string.IsNullOrWhiteSpace(sfn))
                    {
                        errors.Add(string.Format("Row {0}: tag '{1}' has no SystemFullName — skipped", rowNum, tag));
                        skipCount++;
                        continue;
                    }

                    // Get CDevice by SystemFullName
                    IComosDCDevice baseObj;
                    if (!baseBySFN.TryGetValue(sfn, out baseObj))
                    {
                        baseObj = project.GetCDeviceBySystemFullname(sfn, 3);
                        if (baseObj != null)
                            baseBySFN[sfn] = baseObj;
                    }

                    if (baseObj == null)
                    {
                        errors.Add(string.Format("Row {0}: CDevice not found for SFN '{1}' (tag={2})", rowNum, sfn, tag));
                        continue;
                    }

                    // Create object
                    object deviceObj = qsGlobal.GetOrCreateObject(docObj, tag, baseObj, null);
                    if (deviceObj == null)
                    {
                        errors.Add(string.Format("Row {0}: Failed to create object '{1}'", rowNum, tag));
                        continue;
                    }

                    // Force CDevice
                    var dev = deviceObj as IComosDDevice;
                    if (dev != null)
                    {
                        try { qsGlobal.CDeviceChange(dev, baseObj); } catch { }
                        try { dev.CDevice = baseObj; } catch { }

                        // Set description
                        if (!string.IsNullOrEmpty(desc))
                        {
                            try { dev.Description = desc; } catch { }
                        }
                    }

                    createdCount++;
                    createdTags.Add(tag);
                }
                catch (Exception ex)
                {
                    errors.Add(string.Format("Row {0} error: {1}", rowNum, ex.Message));
                }
            }

            return new
            {
                success = true,
                message = string.Format(
                    "Hierarchy creation complete: {0} objects created, {1} skipped, {2} errors.",
                    createdCount, skipCount, errors.Count),
                created = createdCount,
                skipped = skipCount,
                errorCount = errors.Count,
                errors = errors.Count <= 20 ? errors : errors.GetRange(0, 20),
                tags = createdTags.Count <= 30 ? createdTags : createdTags.GetRange(0, 30),
                mode = "tags_only_hierarchy",
            };
        }

        /// <summary>Reads rows from a tags TSV base64 payload (tag\tdescricao\tSystemFullName per line)</summary>
        private static List<string[]> ReadRowsFromTagsPayload(string base64Data)
        {
            var rows = new List<string[]>();
            if (string.IsNullOrWhiteSpace(base64Data)) return rows;

            string decoded;
            try
            {
                byte[] bytes = Convert.FromBase64String(base64Data.Trim());
                decoded = Encoding.UTF8.GetString(bytes);
            }
            catch
            {
                // Not valid base64 — try as raw TSV
                decoded = base64Data;
            }

            var lines = decoded.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
            foreach (var line in lines)
            {
                var cols = line.Split('\t');
                if (cols.Length >= 1 && !string.IsNullOrWhiteSpace(cols[0]))
                    rows.Add(cols);
            }
            return rows;
        }
    }
