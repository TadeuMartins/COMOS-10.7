				}
				try
				{
					string text6 = NormalizeTagForLookup((string)item.AliasFullLabel());
					if (!string.IsNullOrWhiteSpace(text6) && text6.Equals(text, StringComparison.OrdinalIgnoreCase))
					{
						return true;
