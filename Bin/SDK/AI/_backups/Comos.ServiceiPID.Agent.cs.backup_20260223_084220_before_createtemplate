	private static string FindSheetPath(ZipArchive zip, string sheetName)
	{
		try
		{
			ZipArchiveEntry entry = zip.GetEntry("xl/workbook.xml");
			if (entry != null)
			{
				string text = null;
				using (Stream inStream = entry.Open())
				{
					XmlDocument xmlDocument = new XmlDocument();
					xmlDocument.Load(inStream);
					XmlNamespaceManager xmlNamespaceManager = new XmlNamespaceManager(xmlDocument.NameTable);
					xmlNamespaceManager.AddNamespace("s", "http://schemas.openxmlformats.org/spreadsheetml/2006/main");
					XmlNodeList xmlNodeList = xmlDocument.SelectNodes("//s:sheets/s:sheet", xmlNamespaceManager);
					if (xmlNodeList != null)
					{
						foreach (XmlNode item in xmlNodeList)
						{
							string text2 = ((item.Attributes["name"] != null) ? item.Attributes["name"].Value : "");
							if (!text2.Equals(sheetName, StringComparison.OrdinalIgnoreCase) && text != null)
							{
								continue;
							}
							XmlAttribute xmlAttribute = item.Attributes["r:id"];
							if (xmlAttribute == null)
							{
								foreach (XmlAttribute attribute in item.Attributes)
								{
									if (attribute.LocalName == "id")
									{
										xmlAttribute = attribute;
										break;
									}
								}
							}
							if (xmlAttribute != null)
							{
								text = xmlAttribute.Value;
								if (text2.Equals(sheetName, StringComparison.OrdinalIgnoreCase))
								{
									break;
								}
							}
						}
					}
				}
				if (text != null)
				{
					ZipArchiveEntry entry2 = zip.GetEntry("xl/_rels/workbook.xml.rels");
					if (entry2 != null)
					{
						using Stream inStream = entry2.Open();
						XmlDocument xmlDocument = new XmlDocument();
						xmlDocument.Load(inStream);
						foreach (XmlNode childNode in xmlDocument.DocumentElement.ChildNodes)
						{
							if (childNode.Attributes != null && childNode.Attributes["Id"] != null && childNode.Attributes["Id"].Value == text)
							{
								string value = childNode.Attributes["Target"].Value;
								return NormalizeWorksheetTarget(value);
							}
						}
					}
				}
			}
		}
		catch
		{
		}
		string text3 = FindFirstWorksheetEntryPath(zip);
		if (!string.IsNullOrEmpty(text3))
		{
			return text3;
		}
		return "xl/worksheets/sheet1.xml";
	}

	private static string NormalizeWorksheetTarget(string target)
	{
		if (string.IsNullOrWhiteSpace(target))
		{
			return target;
		}
		string text = target.Replace('\\', '/').Trim();
		if (text.StartsWith("/"))
		{
			text = text.Substring(1);
		}
		if (text.StartsWith("xl/", StringComparison.OrdinalIgnoreCase))
		{
			return text;
		}
		if (text.StartsWith("worksheets/", StringComparison.OrdinalIgnoreCase))
		{
			return "xl/" + text;
		}
		return "xl/" + text;
	}

	private static string FindFirstWorksheetEntryPath(ZipArchive zip)
	{
		foreach (ZipArchiveEntry entry in zip.Entries)
		{
			string text = entry.FullName.Replace('\\', '/');
			if (text.StartsWith("xl/worksheets/", StringComparison.OrdinalIgnoreCase) && text.EndsWith(".xml", StringComparison.OrdinalIgnoreCase))
			{
				return text;
			}
		}
		return null;
	}

