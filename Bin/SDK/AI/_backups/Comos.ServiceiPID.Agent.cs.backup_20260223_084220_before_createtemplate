	private static List<string> BuildTagCandidates(string tag)
	{
		List<string> list = new List<string>();
		string text = NormalizeTagForLookup(tag);
		if (string.IsNullOrWhiteSpace(text))
		{
			return list;
		}
		if (!list.Contains(text))
		{
			list.Add(text);
		}
		string text2 = text;
		while (text2.StartsWith("=", StringComparison.Ordinal) || text2.StartsWith("~", StringComparison.Ordinal))
		{
			text2 = text2.Substring(1);
		}
		if (!string.IsNullOrWhiteSpace(text2) && !list.Contains(text2))
		{
			list.Add(text2);
		}
		if (text.StartsWith("=", StringComparison.Ordinal))
		{
			string text3 = text.Substring(1);
			if (!string.IsNullOrWhiteSpace(text3) && !list.Contains(text3))
			{
				list.Add(text3);
			}
		}
		else
		{
			string item = "=" + text;
			if (!list.Contains(item))
			{
				list.Add(item);
			}
		}
		string item2 = "~" + text2;
		if (!string.IsNullOrWhiteSpace(text2) && !list.Contains(item2))
		{
			list.Add(item2);
		}
		string item3 = "=~" + text2;
		if (!string.IsNullOrWhiteSpace(text2) && !list.Contains(item3))
		{
			list.Add(item3);
		}
		string item4 = "~=" + text2;
		if (!string.IsNullOrWhiteSpace(text2) && !list.Contains(item4))
		{
			list.Add(item4);
		}
		return list;
	}

	private static string NormalizeTagForLookup(string value)
	{
		if (string.IsNullOrWhiteSpace(value))
		{
			return string.Empty;
		}
		string text = value.Trim();
		return text.Trim('`', '\'', '"');
	}

