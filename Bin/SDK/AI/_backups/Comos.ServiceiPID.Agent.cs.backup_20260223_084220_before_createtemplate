	[AiFunction("import_equipment_from_excel", "Imports equipment from a ServiceiPID analysis Excel file into the current COMOS electrical diagram. Creates objects, draws them on the document, and establishes connections (From/To). The Excel file must have been generated by the ServiceiPID analysis export.")]
	public object ImportEquipmentFromExcel([DescribeParameter("Full path to the Excel file (.xlsx) generated by ServiceiPID analysis export", ExampleValue = "C:\\temp\\analysis_result.xlsx")] string excelFilePath, [DescribeParameter("SystemUID of the target COMOS document (diagram) to draw equipment on", ExampleValue = "A5B4Z726ZU")] string documentUID, [DescribeParameter("Document type number in COMOS (usually 29 for electrical and P&ID diagrams)", ExampleValue = "29")] int documentType)
	{
		if (Workset == null)
		{
			return new
			{
				success = false,
				error = "Workset not available. COMOS must be running with an open project."
			};
		}
		if (string.IsNullOrWhiteSpace(excelFilePath))
		{
			return new
			{
				success = false,
				error = "excelFilePath is required."
			};
		}
		string text = (excelFilePath ?? "").Trim();
		if (TryExtractPayload(text, new string[3] { "INLINE_B64:", "__INLINE_B64__:", "INLINE64:" }, out var payload))
		{
			string text2 = TryDecodeBase64(payload);
			if (!string.IsNullOrWhiteSpace(text2))
			{
				return DrawSingleObject(documentUID, documentType, text2);
			}
		}
		if (TryExtractPayload(text, new string[4] { "__INLINE__:", "INLINE:", "_INLINE_:", "__INLINE:" }, out var payload2) || TryExtractInlineJson(text, out payload2))
		{
			return DrawSingleObject(documentUID, documentType, payload2);
		}
		if (TryExtractPayload(text, new string[3] { "CONNECT_B64:", "__CONNECT_B64__:", "CONNECT64:" }, out var payload3))
		{
			string text2 = TryDecodeBase64(payload3);
			if (!string.IsNullOrWhiteSpace(text2))
			{
				return ConnectObjects(documentUID, documentType, text2);
			}
		}
		if (TryExtractPayload(text, new string[4] { "__CONNECT__:", "CONNECT:", "_CONNECT_:", "__CONNECT:" }, out var payload4) || TryExtractConnectJson(text, out payload4))
		{
			return ConnectObjects(documentUID, documentType, payload4);
		}
		string text3 = (documentUID ?? "").Trim();
		if (string.IsNullOrWhiteSpace(text3) || text3.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase))
		{
			string errorMessage;
			dynamic activeDocument = GetActiveDocument(out errorMessage);
			if ((object)activeDocument != null)
			{
				try
				{
					text3 = activeDocument.SystemUID;
				}
				catch
				{
				}
			}
			if (string.IsNullOrWhiteSpace(text3))
			{
				return new
				{
					success = false,
					error = (errorMessage ?? "No document is currently open in COMOS. Please open the target drawing (P&ID or Diagram) before using interactive mode.")
				};
			}
		}
		try
		{
			return DoImport(text, text3, documentType, "Sheet1");
		}
		catch (Exception ex)
		{
			return new
			{
				success = false,
				error = ex.Message,
				stackTrace = ex.StackTrace
			};
		}
	}

