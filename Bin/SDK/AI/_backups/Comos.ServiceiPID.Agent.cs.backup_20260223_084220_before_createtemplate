	public object ConnectObjects([DescribeParameter("SystemUID of the COMOS document (diagram) where both objects exist", ExampleValue = "A5B4Z726ZU")] string documentUID, [DescribeParameter("Document type number in COMOS (usually 29 for electrical/P&ID diagrams)", ExampleValue = "29")] int documentType, [DescribeParameter("Tag of the source (upstream) object — its output pin (EB02) will be used", ExampleValue = "=D001")] string sourceTag, [DescribeParameter("Tag of the target (downstream) object — its input pin (EB01) will be used", ExampleValue = "=K001")] string targetTag, [DescribeParameter("COMOS SystemFullName for the source object base (from system_matcher)", ExampleValue = "@30|M41|A50|A10|A10|A60|A70|A30")] string sourceSystemFullName, [DescribeParameter("COMOS SystemFullName for the target object base (from system_matcher)", ExampleValue = "@30|M41|A50|A10|A10|A60|A70|A30")] string targetSystemFullName)
