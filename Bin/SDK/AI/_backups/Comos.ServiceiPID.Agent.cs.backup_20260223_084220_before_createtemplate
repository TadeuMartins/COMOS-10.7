	private static int CellRefToColIndex(string cellRef)
	{
		int num = 0;
		foreach (char c in cellRef)
		{
			if (c >= 'A' && c <= 'Z')
			{
				num = num * 26 + (c - 65 + 1);
				continue;
			}
			if (c >= 'a' && c <= 'z')
			{
				num = num * 26 + (c - 97 + 1);
				continue;
			}
			break;
		}
		return num - 1;
	}

