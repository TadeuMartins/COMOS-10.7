	private static string JsonStr(string json, string field)
	{
		Match match = Regex.Match(json, "\"" + field + "\"\\s*:\\s*\"((?:[^\"\\\\]|\\\\.)*)\"");
		return match.Success ? match.Groups[1].Value.Replace("\\\"", "\"").Replace("\\\\", "\\") : null;
	}

	private static double JsonNum(string json, string field)
	{
		Match match = Regex.Match(json, "\"" + field + "\"\\s*:\\s*([\\d.\\-]+)");
		double result;
		return (match.Success && double.TryParse(match.Groups[1].Value, NumberStyles.Float, CultureInfo.InvariantCulture, out result)) ? result : 0.0;
	}

	private object DrawSingleObject(string documentUID, int documentType, string json)
	{
		string tag = JsonStr(json, "tag");
		string description = JsonStr(json, "description");
		string systemFullName = JsonStr(json, "systemFullName");
		double x = JsonNum(json, "x");
		double y = JsonNum(json, "y");
		return DrawSingleObject(documentUID, documentType, tag, description, systemFullName, x, y);
	}

	private object ConnectObjects(string documentUID, int documentType, string json)
	{
		string sourceTag = JsonStr(json, "sourceTag");
		string targetTag = JsonStr(json, "targetTag");
		string sourceSystemFullName = JsonStr(json, "sourceSFN");
		string targetSystemFullName = JsonStr(json, "targetSFN");
		return ConnectObjects(documentUID, documentType, sourceTag, targetTag, sourceSystemFullName, targetSystemFullName);
	}

