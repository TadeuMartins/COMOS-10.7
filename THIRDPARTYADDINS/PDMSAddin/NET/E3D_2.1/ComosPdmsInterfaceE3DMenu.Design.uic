<?xml version="1.0" encoding="utf-8"?>
<UserInterfaceCustomization xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="www.aveva.com">
  <Tools>
    <ButtonTool Name="COMOS.Navigation.COMOS">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGNavigate()</Macro>
        <Key>Macro:5ad8ac1c-fcee-4794-b35e-7f540ffe5ad8</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>To COMOS</Caption>
      <Tooltip>Navigates to the corresponding COMOS object in the COMOS navigator (if assigned)</Tooltip>
      <TooltipTitle>Navigate to COMOS</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
      <Category>Navigation</Category>
    </ButtonTool>
    <ButtonTool Name="COMOS.Navigation.COMOSPID">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGNavigateToPID()</Macro>
        <Key>Macro:73e39610-d9f2-4121-8667-960ae672861d</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>To COMOS report</Caption>
	  <Tooltip>Navigates to the corresponding COMOS object on the COMOS report (if assigned and placed on a report)</Tooltip>
      <TooltipTitle>Navigate to COMOS report</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
      <DropDownArrowStyle>Segmented</DropDownArrowStyle>
      <IsContextMenu>false</IsContextMenu>
    </ButtonTool>
	<ButtonTool Name="COMOS.Navigation.COMOSPROP">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGNavigateToProperty()</Macro>
        <Key>Macro:73e39610-d9f2-4121-8667-960ae672861d</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>To COMOS properties</Caption>
	  <Tooltip>Navigates to the corresponding COMOS object and opens the properties of the object)</Tooltip>
      <TooltipTitle>Navigate to COMOS properties</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
      <DropDownArrowStyle>Segmented</DropDownArrowStyle>
      <IsContextMenu>false</IsContextMenu>
    </ButtonTool>
    <ButtonTool Name="COMOS.Navigation.2DWS">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGNavigateToScopeInPdms()</Macro>
        <Key>Macro:4e133b82-da4f-4699-835f-155eaccacaee</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>To 2D workspace</Caption>
	  <Tooltip>Navigates to the corresponding object in the currently opened 2D Workspace in E3D (if assigned)</Tooltip>
      <TooltipTitle>Navigate to 2D Workspace</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
    </ButtonTool>
    <ButtonTool Name="COMOS.Navigation.3DWS">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGNavigateToScopeInComos()</Macro>
        <Key>Macro:D3A27916-C10A-43E5-86FF-56D5EDC266C5</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>To 3D workspace</Caption>
	  <Tooltip>Navigates to the corresponding object in the currently opened 3D Workspace in COMOS (if assigned)</Tooltip>
      <TooltipTitle>Navigate to 3D Workspace</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
    </ButtonTool>
    <ButtonTool Name="buttonAttributeDump">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGCallAttributeDump()</Macro>
        <Key>Macro:CA52A170-C775-4364-95EF-6AF853657BE6</Key>
        <Arguments />
      </Command>
      <Image />
      <Caption>Attribute Dump</Caption>
      <DisplayStyle>Default</DisplayStyle>
    </ButtonTool>
    <ButtonTool Name="COMOS.Interface.Start">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGLaunchInterface()</Macro>
        <Key>COMOS.Interface.Start</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>Launch</Caption>
      <Tooltip>Launches the interface. Displays the UI and establishes the connection to COMOS. Please ensure that the interface is already running in COMOS.</Tooltip>
      <TooltipTitle>Launch interface</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
      <Category>Interface</Category>
      <DropDownArrowStyle>Segmented</DropDownArrowStyle>
      <IsContextMenu>false</IsContextMenu>
    </ButtonTool>
    <MenuTool Name="COMOS.Interface.Navigate">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGNavigate()</Macro>
        <Key>COMOS.Interface.Navigate</Key>
        <Arguments />
      </Command>
      <Tools>
          <Tool Name="COMOS.Navigation.2DWS" />
          <Tool Name="COMOS.Navigation.3DWS" />
      </Tools>
      <Image>
         
      </Image>
      <Caption>Navigate</Caption>
      <Tooltip>Navigates to COMOS.</Tooltip>
      <TooltipFormattedText>&lt;p&gt;Navigates to COMOS.&lt;/p&gt;</TooltipFormattedText>
      <DisplayStyle>Default</DisplayStyle>
      <Category>Interface</Category>
      <DropDownArrowStyle>Segmented</DropDownArrowStyle>
      <IsContextMenu>false</IsContextMenu>
    </MenuTool>
  </Tools>
  
  <Tabs>
    <Tab Name="ComosMenu">
      <Caption>COMOS</Caption>
      <Command>
        <Type>Instance</Type>
        <Key />
        <Arguments />
      </Command>
      <ContextualTabGroup>
        <Item>None</Item>
      </ContextualTabGroup>
      <Groups>
        <Group Name="Comos.InterfaceGroup">
          <Tools>
            <Tool Name="COMOS.Interface.Start" LargeImage="True"/>
          </Tools>
          <Caption>Interface</Caption>
        </Group>
        <Group Name="Comos.NavigateGroup">
          <Tools>
            <Tool Name="COMOS.Navigation.COMOSPID" LargeImage="True"/>
			<Tool Name="COMOS.Navigation.COMOSPROP" LargeImage="True"/>
            <Tool Name="COMOS.Navigation.COMOS" LargeImage="True"/>
            <Tool Name="COMOS.Navigation.2DWS" LargeImage="True"/>
            <Tool Name="COMOS.Navigation.3DWS" LargeImage="True"/>
          </Tools>
          <Caption>Navigate</Caption>
        </Group>
	<Group Name="Comos.ReviewGroup">
          <Tools>
            <Tool Name="buttonAttributeDump" />
          </Tools>
          <Caption>Review</Caption>
        </Group>
      </Groups>
    </Tab>
  </Tabs>
	
</UserInterfaceCustomization>