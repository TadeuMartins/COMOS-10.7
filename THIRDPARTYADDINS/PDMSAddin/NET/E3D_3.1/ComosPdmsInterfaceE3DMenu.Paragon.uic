<?xml version="1.0" encoding="utf-8"?>
<UserInterfaceCustomization xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="www.aveva.com">
  <Tools>
    <ButtonTool Name="buttonPipeSpecExport">
      <Command>
        <Type>Macro</Type>
        <Macro>!!paragonUIController.ExportCE()</Macro>
        <Key>Macro:2BDAFD8E-3F52-45E3-97A5-9B00FEFB683C</Key>
        <Arguments />
      </Command>
      <Image />
      <Caption>Export specification</Caption>
      <DisplayStyle>Default</DisplayStyle>
    </ButtonTool>
    <ButtonTool Name="buttonPipeSpecImport">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGShowPDMSPipeSpecAndCatalogImporter()</Macro>
        <Key>Macro:643A4D74-64FF-4924-BBCD-7CC752BFEB0B</Key>
        <Arguments />
      </Command>
      <Image />
      <Caption>Import pipe specs and catalogues</Caption>
      <DisplayStyle>Default</DisplayStyle>
    </ButtonTool>
	<ButtonTool Name="buttonSchemaExport">
      <Command>
        <Type>Macro</Type>
        <Macro>!!SAGShowPDMSSchemaExporter()</Macro>
        <Key>Macro:F8CB85A4-AE1F-41E6-BB8D-AEF367205158</Key>
        <Arguments />
      </Command>
      <Image />
      <Caption>Export E3D schema</Caption>
      <DisplayStyle>Default</DisplayStyle>
    </ButtonTool>
	<ButtonTool Name="COMOS.Interface.Start">
      <Command>  
        <Type>Macro</Type>
        <Macro>!!SAGLaunchInterface()</Macro>
        <Key>COMOS.Interface.Start</Key>
        <Arguments />
      </Command>
      <Image>
      
      </Image>
      <Caption>Launch</Caption>
      <Tooltip>Launches the interface.</Tooltip>
      <TooltipTitle>Launch interface</TooltipTitle>
      <DisplayStyle>Default</DisplayStyle>
      <Category>Interface</Category>
      <DropDownArrowStyle>Segmented</DropDownArrowStyle>
      <IsContextMenu>false</IsContextMenu>
    </ButtonTool>
  </Tools>
 
  <Tabs>
	<Tab Name="ComosMenu">
      <Caption>COMOS</Caption>
      <Command>
        <Type>Instance</Type>
        <Key />
        <Arguments />
      </Command>
      <ContextualTabGroup>
        <Item>None</Item>
      </ContextualTabGroup>
      <Groups>
	    <Group Name="Comos.InterfaceGroup">
          <Tools>
            <Tool Name="COMOS.Interface.Start" LargeImage="True"/>
          </Tools>
          <Caption>Interface</Caption>
        </Group>
        <Group Name="Comos.SpecImportExportGroup">
          <Tools>
            <Tool Name="buttonPipeSpecExport" />
            <Tool Name="buttonPipeSpecImport" />
			<Tool Name="buttonSchemaExport" />
          </Tools>
          <Caption>Specifications</Caption>
        </Group>
      </Groups>
    </Tab>
  </Tabs>
</UserInterfaceCustomization>